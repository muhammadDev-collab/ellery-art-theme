If you require assistance or have questions regarding this code, please contact support@versio.studio.
{% endcomment %}

{%- liquid
  assign text_alignment = 'center'
  assign blocks_alignment = 'left'
  assign desktop_blocks_gap = section.settings.desktop_blocks_gap
	  assign mobile_blocks_gap = section.settings.mobile_blocks_gap
	  assign block_padding = section.settings.block_padding
	  assign block_elements_gap = section.settings.block_elements_gap

	  assign heading_block = section.blocks | where: 'type', 'heading' | first
	  assign review_summary_block = section.blocks | where: 'type', 'review_summary' | first
	  assign testimonial_blocks = section.blocks | where: 'type', 'star_card'
	  assign block_count = testimonial_blocks.size
	-%}

{%- style -%}
  .vd-l { display: none !important; }
  {% if heading_block != blank and heading_block.settings.heading_custom_font and heading_block.settings.heading_font != blank %}
    {{ heading_block.settings.heading_font | font_face: font_display: 'swap' }}
  {% endif %}

  {% if review_summary_block != blank and review_summary_block.settings.custom_font and review_summary_block.settings.font != blank %}
    {{ review_summary_block.settings.font | font_face: font_display: 'swap' }}
  {% endif %}

  {{ section.settings.block_title_font | font_face: font_display: 'swap' }}
  {{ section.settings.block_description_font | font_face: font_display: 'swap' }}

  {% if heading_block != blank and heading_block.settings.heading_custom_font %}
    #Star-Cards-{{ section.id }} .vso-star-cards__title {
      font-family: {{ heading_block.settings.heading_font.family }}, {{ heading_block.settings.heading_font.fallback_families }};
      font-style: {{ heading_block.settings.heading_font.style }};
    }
  {% endif %}

  {% if review_summary_block != blank and review_summary_block.settings.custom_font %}
    #Star-Cards-{{ section.id }} .vso-star-cards__review-summary {
      font-family: {{ review_summary_block.settings.font.family }}, {{ review_summary_block.settings.font.fallback_families }};
      font-style: {{ review_summary_block.settings.font.style }};
    }
  {% endif %}

  {% if section.settings.custom_block_title_font %}
    #Star-Cards-{{ section.id }} .vso-star-cards__block-title {
      font-family: {{ section.settings.block_title_font.family }}, {{ section.settings.block_title_font.fallback_families }};
      font-style: {{ section.settings.block_title_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_block_description_font %}
    #Star-Cards-{{ section.id }} .vso-star-cards__block-description {
      font-family: {{ section.settings.block_description_font.family }}, {{ section.settings.block_description_font.fallback_families }};
      font-style: {{ section.settings.block_description_font.style }};
    }
  {% endif %}

  .vso-star-cards {
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .vso-star-cards__title {
    margin: 0;
    text-align: center;
  }

  {% if heading_block != blank %}
    #Star-Cards-{{ section.id }} .vso-star-cards__title:not(.vso-star-cards__title--custom) {
      color: {{ heading_block.settings.heading_color | default: '#000000' }};
    }
  {% endif %}

  .vso-star-cards__title--custom {
    line-height: {{ heading_block.settings.heading_line_height | default: 130 }}%;
    font-size: {{ heading_block.settings.heading_size_desktop | default: 40 }}px;
    color: {{ heading_block.settings.heading_color | default: '#000000' }};
    font-weight: {{ heading_block.settings.heading_font_weight | default: 700 }};
  }

  .vso-star-cards__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  {% if review_summary_block != blank %}
    .vso-star-cards__review-summary-wrap {
      width: 100%;
      display: flex;
      justify-content: center;
    }

  .vso-star-cards__review-summary-wrap {
    margin-top: var(--vso-block-spacing-top-mobile, 0px);
    margin-bottom: var(--vso-block-spacing-bottom-mobile, 0px);
  }

  @media screen and (min-width: 750px) {
    .vso-star-cards__review-summary-wrap {
      margin-top: var(--vso-block-spacing-top-desktop, 0px);
      margin-bottom: var(--vso-block-spacing-bottom-desktop, 0px);
    }
  }

    .vso-star-cards__review-summary {
      display: inline-flex;
      align-items: center;
      gap: {{ review_summary_block.settings.gap | default: 10 }}px;
      padding: {{ review_summary_block.settings.padding_y | default: 8 }}px {{ review_summary_block.settings.padding_x | default: 14 }}px;
      border-radius: {{ review_summary_block.settings.radius | default: 999 }}px;
      background-color: {{ review_summary_block.settings.bg_color | default: '#111111' }};
      color: {{ review_summary_block.settings.text_color | default: '#FFFFFF' }};
      line-height: {{ review_summary_block.settings.line_height | default: 140 }}%;
      font-size: {{ review_summary_block.settings.size_desktop | default: 14 }}px;
      {% if section.settings.enable_advanced_settings %}
        font-weight: {{ review_summary_block.settings.font_weight | default: 500 }};
      {% endif %}
    }

    .vso-star-cards__review-summary-stars {
      display: inline-flex;
      align-items: center;
      gap: 2px;
      color: {{ review_summary_block.settings.stars_color | default: '#FFFFFF' }};
    }

    .vso-star-cards__review-summary-star {
      width: {{ review_summary_block.settings.stars_size | default: 16 }}px;
      height: {{ review_summary_block.settings.stars_size | default: 16 }}px;
      display: block;
      flex-shrink: 0;
    }

    .vso-star-cards__review-summary-text {
      color: inherit;
    }
  {% endif %}

  .vso-star-cards__header {
    margin-top: var(--vso-block-spacing-top-mobile, 0px);
    margin-bottom: var(--vso-block-spacing-bottom-mobile, 0px);
  }

  @media screen and (min-width: 750px) {
    .vso-star-cards__header {
      margin-top: var(--vso-block-spacing-top-desktop, 0px);
      margin-bottom: var(--vso-block-spacing-bottom-desktop, 0px);
    }
  }

  .vso-star-cards__swiper {
    width: 100%;
    padding: 30px 0px !important;
    overflow: visible;
    position: relative;
  }


  .vso-node { display: none; }
  .vso-node--v2 { display: block; }

  @media screen and (min-width: 750px) {
    .vso-star-cards__swiper {
      mask: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
      -webkit-mask: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    }
  }
  @media screen and (max-width: 749px) {
    .vso-star-cards__swiper {
      mask: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
      -webkit-mask: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    }
  }

  {% if section.settings.enable_equal_height %}
    .vso-star-cards__swiper {
      height: auto;
    }

    .vso-star-cards__swiper .swiper-wrapper {
      align-items: stretch;
      display: flex;
    }

    .vso-star-cards__swiper .swiper-slide {
      height: auto;
      display: flex;
      flex-direction: column;
    }

    .vso-star-cards__block {
      justify-content: flex-start;
    }

    .vso-star-cards__author-container {
      margin-top: auto;
    }
  {% endif %}

  .vso-star-cards__slide {
    width: auto;
    max-width: {{ section.settings.desktop_card_width }}px;
    min-width: 280px;
    padding-bottom: 12px;
    box-sizing: border-box;
    {% if section.settings.enable_equal_height %}
      display: flex;
      height: 100%;
    {% endif %}
  }

  .vso-star-cards__block {
    --vso-star-card-padding: {{ block_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: {{ blocks_alignment }};
    padding: var(--vso-star-card-padding);
    background-color: {{ section.settings.block_background_color }};
    border-radius: {{ section.settings.block_border_radius }}px;
    border: {{ section.settings.block_border_width }}px solid {{ section.settings.block_border_color }};
    gap: {{ block_elements_gap }}px;
    text-align: {{ blocks_alignment }};
    transition: transform 0.3s ease;
    {% if section.settings.enable_card_shadow %}
      box-shadow: {{ section.settings.card_shadow_color | color_modify: 'alpha', 0.24 }} 0px 3px 8px;
    {% endif %}
    {% if section.settings.enable_equal_height %}
      width: 100%;
      height: 100%;
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .swiper-slide-active .vso-star-cards__block,
    .swiper-slide-duplicate-active .vso-star-cards__block {
      transform: scale(1.1);
    }
  }

  .vso-star-cards__stars {
    display: flex;
    gap: 1px;
    margin-bottom: 0px;
  }

  .vso-star-cards__star {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
  }

  .vso-star-cards__star svg {
    width: 100%;
    height: 100%;
  }

  .vso-star-cards__star svg path { fill: {{ section.settings.star_color }}; }

  .vso-star-cards__block-description {
    width: 100%;
    margin: 0;
    position: relative;
    padding-left: 0;
  }

  .vso-star-cards__block-title {
    width: 100%;
    margin: 0;
    font-weight: 400;
  }

  .vso-star-cards__block-title--custom {
    line-height: {{ section.settings.block_title_line_height }}%;
    font-size: {{ section.settings.block_title_size_desktop }}px;
    color: {{ section.settings.block_title_color }};
  }

  .vso-star-cards__block-description--custom {
    line-height: {{ section.settings.block_description_line_height }}%;
    font-size: {{ section.settings.block_description_size_desktop }}px;
    color: {{ section.settings.block_description_color }};
    font-weight: {{ section.settings.block_description_font_weight }};
  }

  .vso-star-cards__block-description::before { display: none; }

  .vso-star-cards__media {
    width: 100%;
    max-height: {{ section.settings.card_image_max_height_mobile }}px;
    border-radius: {{ section.settings.block_border_radius }}px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .vso-star-cards__media-image {
    width: 100%;
    height: auto;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .vso-star-cards__media {
      max-height: {{ section.settings.card_image_max_height_desktop }}px;
    }
  }

  .vso-star-cards__block--full-image .vso-star-cards__media {
    margin-top: calc(var(--vso-star-card-padding) * -1);
    margin-left: calc(var(--vso-star-card-padding) * -1);
    margin-right: calc(var(--vso-star-card-padding) * -1);
    width: calc(100% + (var(--vso-star-card-padding) * 2));
    border-top-left-radius: max(0px, calc({{ section.settings.block_border_radius }}px - {{ section.settings.block_border_width }}px));
    border-top-right-radius: max(0px, calc({{ section.settings.block_border_radius }}px - {{ section.settings.block_border_width }}px));
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .vso-star-cards__block--full-image .vso-star-cards__media-image {
    border-radius: 0;
  }

  .vso-star-cards__verified-row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .vso-star-cards__verified-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: {{ section.settings.block_verified_color }};
  }

  .vso-star-cards__footer {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .vso-star-cards__footer .vso-star-cards__author-container {
    margin-top: 0;
  }

  .vso-star-cards__author-container {
    width: auto;
    display: flex;
    align-items: center;
    gap: {{ section.settings.author_container_gap }}px;
    flex: 1;
    min-width: 0;
  }

  .vso-star-cards__author-circle {
    width: {{ section.settings.author_circle_size }}px;
    height: {{ section.settings.author_circle_size }}px;
    border-radius: 50%;
    background-color: {{ section.settings.author_circle_background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    font-weight: 600;
    color: {{ section.settings.author_circle_text_color }};
    flex-shrink: 0;
    overflow: hidden;
  }

  .vso-star-cards__author-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vso-star-cards__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .vso-star-cards__block-author {
    width: auto;
    margin: 0;
    line-height: {{ section.settings.block_author_line_height }}%;
    font-size: {{ section.settings.block_author_size_desktop }}px;
    color: {{ section.settings.block_author_color }};
    font-weight: {{ section.settings.block_author_font_weight }};
  }

  .vso-star-cards__block-verified {
    width: auto;
    margin: 0;
    line-height: {{ section.settings.block_verified_line_height }}%;
    font-size: {{ section.settings.block_verified_size_desktop }}px;
    color: {{ section.settings.block_verified_color }};
    font-weight: {{ section.settings.block_verified_font_weight }};
  }

  .vso-star-cards__author-meta {
    margin: 0;
    line-height: {{ section.settings.block_verified_line_height }}%;
    font-size: {{ section.settings.block_verified_size_desktop }}px;
    color: {{ section.settings.block_verified_color }};
    font-weight: {{ section.settings.block_verified_font_weight }};
  }

	  .vso-star-cards__stars {
	    margin-left: auto;
	  }

	  @media screen and (max-width: 749px) {
	    .vso-star-cards__swiper {
	      padding: 10px 0px !important;
	    }

	    .vso-star-cards__review-summary-wrap {
	      padding-left: 15px;
	      padding-right: 15px;
	      box-sizing: border-box;
	    }

	    .vso-star-cards__slide {
	      min-width: 260px;
	      max-width: 300px;
        padding-bottom: 10px;
	    }

	    .vso-star-cards__title--custom {
	      font-size: {{ heading_block.settings.heading_size_mobile | default: 32 }}px;
	    }

	    {% if review_summary_block != blank %}
	      .vso-star-cards__review-summary {
	        font-size: {{ review_summary_block.settings.size_mobile | default: 13 }}px;
	      }
	    {% endif %}

	    .vso-star-cards__block-description--custom {
	      font-size: {{ section.settings.block_description_size_mobile }}px;
	    }

	    .vso-star-cards__block-title--custom {
	      font-size: {{ section.settings.block_title_size_mobile }}px;
	    }

	    .vso-star-cards__block-author {
	      font-size: {{ section.settings.block_author_size_mobile }}px;
	    }

	    .vso-star-cards__block-verified {
	      font-size: {{ section.settings.block_verified_size_mobile }}px;
	    }

	    .vso-star-cards__author-meta {
	      font-size: {{ section.settings.block_verified_size_mobile }}px;
	    }

	    .vso-star-cards__author-circle {
	      width: {{ section.settings.author_circle_size_mobile }}px;
	      height: {{ section.settings.author_circle_size_mobile }}px;
	      font-size: 20px;
	    }

	    /* Rating summary removed (will be replaced). */
	  }

  /* ── Section root ── */
  #shopify-section-{{ section.id }} {
    --section-border-radius: 0px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    border-radius: var(--section-border-radius);
    padding: 0;
    width: 100%;
    max-width: 100%;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      {% if section.settings.background_style == 'gradient' %}
        background: {{ section.settings.background_gradient | default: 'linear-gradient(180deg, #F7F7F7 0%, #FFFFFF 100%)' }};
      {% else %}
        background-color: {{ section.settings.background_color }};
      {% endif %}
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      --section-border-radius: {% if section.settings.full_width_desktop %}0{% else %}{{ section.settings.section_border_radius | default: 16 }}{% endif %}px;
      margin-top: {{ section.settings.margin_top_desktop }}px;
      margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
      {% if section.settings.full_width_desktop %}
        {% if section.settings.background_style == 'gradient' %}
          background: {{ section.settings.background_gradient | default: 'linear-gradient(180deg, #F7F7F7 0%, #FFFFFF 100%)' }};
        {% else %}
          background-color: {{ section.settings.background_color }};
        {% endif %}
      {% else %}
        background: transparent;
      {% endif %}
    }
  }

  /* ── Container ── */
  #shopify-section-{{ section.id }} .vso-star-cards {
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    max-width: var(--page-content-width, var(--page-width, 1440px));
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    border-radius: var(--section-border-radius);
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .vso-star-cards {
      background: transparent;
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-star-cards {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      {% if section.settings.full_width_desktop %}
        max-width: 100%;
        background: transparent;
      {% else %}
        {% if section.settings.background_style == 'gradient' %}
          background: {{ section.settings.background_gradient | default: 'linear-gradient(180deg, #F7F7F7 0%, #FFFFFF 100%)' }};
        {% else %}
          background-color: {{ section.settings.background_color }};
        {% endif %}
      {% endif %}
    }
  }

  {% unless section.settings.full_width_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .vso-star-cards {
        width: calc(100% - (2 * var(--page-margin, 40px)));
      }
    }
  {% endunless %}

  .vso-star-cards__navigation {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
  }
  @media screen and (min-width: 750px) {
    {% unless section.settings.show_navigation_desktop %}
      .vso-star-cards__navigation {
        display: none;
      }
    {% endunless %}
  }

  @media screen and (max-width: 749px) {
    {% unless section.settings.show_navigation_mobile %}
      .vso-star-cards__navigation {
        display: none;
      }
    {% endunless %}
  }

  .vso-star-cards__nav-prev,
  .vso-star-cards__nav-next {
    position: absolute;
    width: {{ section.settings.nav_arrow_size }}px;
    height: {{ section.settings.nav_arrow_size }}px;
    background-color: {{ section.settings.nav_arrow_bg_color }};
    border: {{ section.settings.nav_arrow_border_width }}px solid {{ section.settings.nav_arrow_border_color }};
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    {% if section.settings.nav_arrow_shadow_enable %}
      box-shadow: {{ section.settings.nav_arrow_shadow_color | color_modify: 'alpha', 0.24 }} 0px 3px 8px;
    {% endif %}
  }

  .vso-star-cards__nav-prev svg,
  .vso-star-cards__nav-next svg {
    width: {{ section.settings.nav_arrow_size | times: 0.4 | round: 0 }}px;
    height: {{ section.settings.nav_arrow_size | times: 0.4 | round: 0 }}px;
    color: {{ section.settings.nav_arrow_icon_color }};
    transition: color 0.3s ease;
  }

  .vso-star-cards__nav-prev:hover,
  .vso-star-cards__nav-next:hover {
    border-color: {{ section.settings.nav_arrow_border_color | color_darken: 10 }};
    {% if section.settings.nav_arrow_shadow_enable %}
      box-shadow: {{ section.settings.nav_arrow_shadow_color | color_modify: 'alpha', 0.32 }} 0px 4px 12px;
    {% endif %}
  }

  .vso-star-cards__nav-prev:hover svg,
  .vso-star-cards__nav-next:hover svg {
    color: {{ section.settings.nav_arrow_icon_color | color_darken: 20 }};
  }

  .vso-star-cards__nav-prev.swiper-button-disabled,
  .vso-star-cards__nav-next.swiper-button-disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
{%- endstyle -%}



{%- if request.design_mode -%}
  <div class="vso-require-script">
    <div class="vso-warning">
      <div class="vso-warning__left">
        <div class="vso-warning__badge">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
            <path d="M10 6.75a.75.75 0 0 1 .75.75v3.5a.75.75 0 1 1-1.5 0v-3.5a.75.75 0 0 1 .75-.75Z" fill="currentColor"/>
            <path d="M11 13.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z" fill="currentColor"/>
            <path fill-rule="evenodd" d="M10 3.5c-1.045 0-1.784.702-2.152 1.447a449.26 449.26 0 0 1-2.005 3.847l-.028.052a403.426 403.426 0 0 0-2.008 3.856c-.372.752-.478 1.75.093 2.614.57.863 1.542 1.184 2.464 1.184h7.272c.922 0 1.895-.32 2.464-1.184.57-.864.465-1.862.093-2.614-.21-.424-1.113-2.147-2.004-3.847l-.032-.061a429.497 429.497 0 0 1-2.005-3.847c-.368-.745-1.107-1.447-2.152-1.447Zm-.808 2.112c.404-.816 1.212-.816 1.616 0 .202.409 1.112 2.145 2.022 3.88a418.904 418.904 0 0 1 2.018 3.875c.404.817 0 1.633-1.212 1.633h-7.272c-1.212 0-1.617-.816-1.212-1.633.202-.408 1.113-2.147 2.023-3.883a421.932 421.932 0 0 0 2.017-3.872Z" fill="currentColor"/>
          </svg>
          <span>Action Required</span>
        </div>
        <h2 class="vso-warning__title">App Embeds Are Disabled</h2>
        <p class="vso-warning__subtitle">Enable the Versio Sections app embed in your theme editor to use this section.</p>
        <div class="vso-warning__steps">
          <div class="vso-warning__step">
            <span class="vso-warning__step-number">1</span>
            <span>Click the <strong>App embeds</strong> icon (puzzle piece) at the top of the left sidebar</span>
          </div>
          <div class="vso-warning__step">
            <span class="vso-warning__step-number">2</span>
            <span>Toggle on <strong>Versio Sections</strong></span>
          </div>
          <div class="vso-warning__step">
            <span class="vso-warning__step-number">3</span>
            <span>Click <strong>Save</strong> in the top right</span>
          </div>
        </div>
