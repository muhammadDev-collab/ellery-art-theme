<script defer>
document.addEventListener('DOMContentLoaded', function() {
  const starCardsSection = document.getElementById('Star-Cards-{{ section.id }}');
  if (!starCardsSection) return;

  const swiperEl = starCardsSection.querySelector('.vso-star-cards__swiper');
  if (!swiperEl) return;

  const prevEl = starCardsSection.querySelector('.vso-star-cards__nav-prev');
  const nextEl = starCardsSection.querySelector('.vso-star-cards__nav-next');

  const starCardsSwiper = new Swiper(swiperEl, {
    loop: true,
    slidesPerView: 'auto',
    centeredSlides: true,
    spaceBetween: {{ desktop_blocks_gap }},
    grabCursor: true,
    speed: 600,
    
    {% if section.settings.enable_equal_height %}
    watchSlidesProgress: true,
    {% endif %}
    
    navigation: {
      nextEl: nextEl,
      prevEl: prevEl,
    },
    
	    breakpoints: {
	      0: {
	        spaceBetween: {{ mobile_blocks_gap }},
	      },
	      750: {
	        spaceBetween: {{ desktop_blocks_gap }},
	      }
	    },
	    on: {
	      init: function() {
	        setTimeout(() => {
	          this.updateSlidesClasses();
	          {% if section.settings.enable_equal_height %}
	            equalizeSlideHeights();
	          {% endif %}
	          positionNavButtons(this);
	        }, 100);
	      },
	      slideChangeTransitionEnd: function() {
	        {% if section.settings.enable_equal_height %}
	          equalizeSlideHeights();
	        {% endif %}
	        positionNavButtons(this);
	      }
	    }
	  });

  {% if section.settings.enable_equal_height %}
  function equalizeSlideHeights() {
    const slides = swiperEl.querySelectorAll('.swiper-slide');
    const blocks = swiperEl.querySelectorAll('.vso-star-cards__block');
    
    if (slides.length === 0 || blocks.length === 0) return;
    
    blocks.forEach(block => {
      block.style.height = 'auto';
    });
    
    let maxHeight = 0;
    blocks.forEach(block => {
      const height = block.offsetHeight;
      if (height > maxHeight) {
        maxHeight = height;
      }
    });
    
    blocks.forEach(block => {
      block.style.height = maxHeight + 'px';
    });
  }

  window.addEventListener('resize', function() {
    setTimeout(() => {
      equalizeSlideHeights();
      positionNavButtons(starCardsSwiper);
    }, 100);
  });
  {% endif %}

	  function positionNavButtons(swiper) {
	    if (!swiper || !swiper.el || !prevEl || !nextEl) return;
	    if (!swiper.slides || swiper.slides.length === 0) return;

    const activeIndex = swiper.activeIndex;
    const prevSlide = swiper.slides[activeIndex - 1] || swiper.slides[swiper.slides.length - 1];
    const nextSlide = swiper.slides[activeIndex + 1] || swiper.slides[0];

    if (!prevSlide || !nextSlide) return;

	    const swiperRect = swiper.el.getBoundingClientRect();
	    const prevRect = prevSlide.getBoundingClientRect();
	    const nextRect = nextSlide.getBoundingClientRect();

	    const prevW = prevEl.offsetWidth || 0;
	    const nextW = nextEl.offsetWidth || 0;
	    const prevH = prevEl.offsetHeight || 0;
	    const nextH = nextEl.offsetHeight || 0;

	    const arrowOutset = {% if section.settings.enable_advanced_settings %}{{ section.settings.nav_arrow_gap | default: 10 | json }}{% else %}10{% endif %};
	    const arrowYOffset = {% if section.settings.enable_advanced_settings %}{{ section.settings.nav_arrow_top_spacing | default: 0 | json }}{% else %}0{% endif %};
	    const minLeftPrev = -prevW;
	    const minLeftNext = -nextW;
	    const maxLeftPrev = swiperRect.width;
	    const maxLeftNext = swiperRect.width;
	    const maxTopPrev = Math.max(0, swiperRect.height - prevH);
	    const maxTopNext = Math.max(0, swiperRect.height - nextH);

	    const prevLeftRaw = (prevRect.left - swiperRect.left) - (prevW / 2) - arrowOutset;
	    const nextLeftRaw = (nextRect.right - swiperRect.left) - (nextW / 2) + arrowOutset;
	    const prevLeft = Math.min(maxLeftPrev, Math.max(minLeftPrev, prevLeftRaw));
	    const nextLeft = Math.min(maxLeftNext, Math.max(minLeftNext, nextLeftRaw));

	    const prevTopRaw = (prevRect.top - swiperRect.top) + (prevRect.height / 2) - (prevH / 2) + arrowYOffset;
	    const nextTopRaw = (nextRect.top - swiperRect.top) + (nextRect.height / 2) - (nextH / 2) + arrowYOffset;
	    const prevTop = Math.min(maxTopPrev, Math.max(0, prevTopRaw));
	    const nextTop = Math.min(maxTopNext, Math.max(0, nextTopRaw));

	    prevEl.style.top = `${prevTop}px`;
	    nextEl.style.top = `${nextTop}px`;
	    prevEl.style.left = `${prevLeft}px`;
	    nextEl.style.left = `${nextLeft}px`;
	  }

  if (!{{ section.settings.enable_equal_height | json }}) {
    window.addEventListener('resize', function() {
      setTimeout(() => positionNavButtons(starCardsSwiper), 100);
    });
  }
});
</script>

