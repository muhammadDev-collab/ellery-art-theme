                      {%- endif -%}

                    {%- when 'description' -%}
                      {%- assign vso_description_content = block.settings.description_text | default: vso_product.description -%}
                      {%- if vso_description_content != blank -%}
                        <div class="vso-product-info__description" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                          {{ vso_description_content }}
                        </div>
                      {%- endif -%}

                        {%- when 'text' -%}
                          {%- if block.settings.text != blank -%}
                            <div
                              class="vso-product-info__text rte"
                              data-block-id="{{ block.id }}"
                              {{ block.shopify_attributes }}
                              style="
                                --vso-text-size: {{ block.settings.font_size }}px;
                                --vso-text-size-mobile: {{ block.settings.font_size_mobile }}px;
                                --vso-text-color: {{ block.settings.text_color }};
                                --vso-text-highlight-color: {{ block.settings.text_highlight_color }};
                                --vso-text-highlight-text-color: {{ block.settings.text_highlight_text_color }};
                                --vso-text-align: {{ block.settings.text_alignment }};
                                --vso-text-align-mobile: {{ block.settings.text_alignment_mobile }};
                                {%- if block.settings.text_custom_font -%}
                                  font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
                                  font-style: {{ block.settings.text_font.style }};
                                {%- endif -%}
                              "
                            >
                              {%- assign vso_text_parts = block.settings.text | split: '_' -%}
                              {%- assign vso_text_highlight_toggle = 'false' -%}
                              {%- for vso_text_part in vso_text_parts -%}
                                {%- if vso_text_highlight_toggle == 'true' -%}
                                  <span class="vso-product-info__important-word">{{ vso_text_part }}</span>
                                  {%- assign vso_text_highlight_toggle = 'false' -%}
                                {%- else -%}
                                  {{ vso_text_part }}
                                  {%- assign vso_text_highlight_toggle = 'true' -%}
                                {%- endif -%}
                              {%- endfor -%}
                            </div>
                          {%- endif -%}

                    {%- when 'media_testimonial' -%}
                      {%- unless block.settings.hide_on_mobile -%}
                      {%- liquid
                        assign vso_testimonial_has_content = false
                    if block.settings.title != blank
                      assign vso_testimonial_has_content = true
                    elsif block.settings.body != blank
                      assign vso_testimonial_has_content = true
                    elsif block.settings.author != blank
                      assign vso_testimonial_has_content = true
                    elsif block.settings.image != blank
                      assign vso_testimonial_has_content = true
                    endif
                  -%}

                      {%- if vso_testimonial_has_content -%}
                        <div
                          class="vso-product-info__testimonial-card vso-product-info__testimonial-card--mobile{% if block.settings.enable_glare %} vso-product-info__testimonial-card--glare{% endif %}{% if block.settings.image_position == 'top' %} vso-product-info__testimonial-card--image-top{% endif %}"
                          data-block-id="{{ block.id }}"
                          {{ block.shopify_attributes }}
                        >
                      <div class="vso-product-info__testimonial-inner">
                        {%- if block.settings.image != blank -%}
                          <div
                            class="vso-product-info__testimonial-image"
                            aria-hidden="true"
                            style="
                              width: {{ block.settings.image_size_mobile | default: block.settings.image_size }}px;
                              height: {{ block.settings.image_size_mobile | default: block.settings.image_size }}px;
                              border-radius: {{ block.settings.image_radius_mobile | default: block.settings.image_radius }}px;
                            "
                          >
                            {{
                              block.settings.image
                              | image_url: width: 160
                              | image_tag: loading: 'lazy', alt: ''
                            }}
                          </div>
                        {%- endif -%}
                        <div class="vso-product-info__testimonial-content">
                          {%- if block.settings.title != blank -%}
                            <{{ block.settings.title_render_as | default: 'p' }} class="vso-product-info__testimonial-title">
                              {{ block.settings.title }}
                            </{{ block.settings.title_render_as | default: 'p' }}>
                          {%- endif -%}
                          {%- if block.settings.body != blank -%}
                            <{{ block.settings.description_render_as | default: 'p' }} class="vso-product-info__testimonial-text">
                              {{ block.settings.body }}
                            </{{ block.settings.description_render_as | default: 'p' }}>
                          {%- endif -%}
                          {%- if block.settings.author != blank -%}
                            <{{ block.settings.author_render_as | default: 'p' }} class="vso-product-info__testimonial-author">
                              {{ block.settings.author }}
                            </{{ block.settings.author_render_as | default: 'p' }}>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                      {%- endunless -%}
                {%- when 'custom_liquid' -%}
                  <div class="vso-product-info__custom-liquid" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                    {{ block.settings.custom_liquid }}
                  </div>

                {%- when '@app' -%}
                  <div data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                    {% render block %}
                  </div>

              {%- endcase -%}
            {%- endfor -%}

            {%- if section.blocks.size == 0 -%}
              <h1 class="vso-product-info__title">{{ vso_product.title }}</h1>
              <div class="vso-product-info__price">
                <span class="vso-product-info__price-current" data-vso-price>
                  {%- if settings.currency_code_enabled_product_pages -%}
                    {{ vso_current_variant.price | money_with_currency }}
                  {%- else -%}
                    {{ vso_current_variant.price | money }}
                  {%- endif -%}
                </span>
              </div>
                  {%- liquid
                    assign vso_product_form_id = 'vso-product-form-' | append: section.id
                    assign vso_can_add_to_cart = vso_current_variant.available
                    assign vso_add_to_cart_text = 'products.product.add_to_cart' | t
                    if vso_add_to_cart_text contains 'Translation missing'
                      assign vso_add_to_cart_text = 'Add to cart'
                    endif
                    if vso_form_block.settings.atc_custom_text != blank
                      assign vso_add_to_cart_text = vso_form_block.settings.atc_custom_text
                    endif
                    assign vso_sold_out_text = 'products.product.sold_out' | t
                    if vso_sold_out_text contains 'Translation missing'
                      assign vso_sold_out_text = 'Sold out'
                    endif
                    if vso_form_block.settings.sold_out_custom_text != blank
                      assign vso_sold_out_text = vso_form_block.settings.sold_out_custom_text
                    endif
                    if vso_can_add_to_cart == false
                      assign vso_add_to_cart_text = vso_sold_out_text
                    endif
                  -%}
                  {%- form 'product', vso_product, id: vso_product_form_id, class: 'vso-product-info__form', novalidate: 'novalidate' -%}
                    <input type="hidden" name="id" value="{{ vso_current_variant.id }}" data-vso-variant-id>
                    <div class="vso-product-info__actions">
                  <div class="vso-product-info__qty" data-vso-qty>
                    <button class="vso-product-info__qty-button" type="button" data-vso-qty-minus aria-label="Decrease quantity">−</button>
                    <input
                      class="vso-product-info__qty-input"
                      type="number"
                      name="quantity"
                      value="{{ vso_current_variant.quantity_rule.min | default: 1 }}"
                      min="{{ vso_current_variant.quantity_rule.min | default: 1 }}"
                      step="{{ vso_current_variant.quantity_rule.increment | default: 1 }}"
                      {% if vso_current_variant.quantity_rule.max != blank %}max="{{ vso_current_variant.quantity_rule.max }}"{% endif %}
                      inputmode="numeric"
                      data-vso-qty-input
                    >
                    <button class="vso-product-info__qty-button" type="button" data-vso-qty-plus aria-label="Increase quantity">+</button>
                  </div>
                      <button
                        type="submit"
                        name="add"
                        class="vso-product-info__atc{% if vso_form_block.settings.show_button_subtext and vso_form_block.settings.button_subtext != blank %} vso-product-info__atc--has-subtext{% endif %}"
                        data-vso-atc
                        data-vso-add-text="{{ vso_add_to_cart_text | escape }}"
                        data-vso-sold-out-text="{{ vso_sold_out_text | escape }}"
                        {% unless vso_can_add_to_cart %}disabled{% endunless %}
                      >
                        <span class="vso-product-info__atc-main">
                          <span data-vso-atc-text>{{ vso_add_to_cart_text }}</span>
                        </span>
                        {%- if vso_form_block.settings.show_button_subtext and vso_form_block.settings.button_subtext != blank -%}
                          <span class="vso-product-info__atc-subtext">
                            {%- if vso_form_block.settings.button_subtext_icon != blank -%}
                              {{ vso_form_block.settings.button_subtext_icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
                            {%- endif -%}
                            {{ vso_form_block.settings.button_subtext }}
                          </span>
                        {%- endif -%}
                      </button>
                    </div>
                  {%- endform -%}
              {%- if vso_product.description != blank -%}
                <div class="vso-product-info__description">
                  {{ vso_product.description }}
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var sectionRoot = document.getElementById('shopify-section-{{ section.id }}');
      if (!sectionRoot) return;

          var mainMediaContainer = sectionRoot.querySelector('[data-vso-main-media]');
          var mainImage = sectionRoot.querySelector('[data-vso-main-image]') || mainMediaContainer?.querySelector('img');
          var thumbnails = sectionRoot.querySelectorAll('[data-vso-thumbnail]');
          var mediaDataNode = sectionRoot.querySelector('[data-vso-media-data]');
          var counterIndexNode = sectionRoot.querySelector('[data-vso-media-index]');
          var counterTotalNode = sectionRoot.querySelector('[data-vso-media-total]');
          var mediaDotButtons = Array.prototype.slice.call(sectionRoot.querySelectorAll('[data-vso-media-dot]') || []);
          var thumbnailsContainer = sectionRoot.querySelector('[data-vso-thumbnails]');
          var thumbnailsWrap = sectionRoot.querySelector('[data-vso-thumbnails-wrap]');
          var thumbScrollPrevButton = sectionRoot.querySelector('[data-vso-thumb-scroll-prev]');
          var thumbScrollNextButton = sectionRoot.querySelector('[data-vso-thumb-scroll-next]');
      var prevMediaButton = sectionRoot.querySelector('[data-vso-media-prev]');
      var nextMediaButton = sectionRoot.querySelector('[data-vso-media-next]');
      var variantsDataNode = sectionRoot.querySelector('[data-vso-variants]');
          var forms = sectionRoot.querySelectorAll('form.vso-product-info__form');
          var priceNode = sectionRoot.querySelector('[data-vso-price]');
          var compareAtNode = sectionRoot.querySelector('[data-vso-compare-at]');
          var skuNode = sectionRoot.querySelector('[data-vso-sku]');
          var cartAddUrl = {{ routes.cart_add_url | json }};

          var variantsData = [];
          if (variantsDataNode && variantsDataNode.textContent) {
            try {
              variantsData = JSON.parse(variantsDataNode.textContent) || [];
        } catch (e) {
          variantsData = [];
        }
      }

          var thumbnailButtons = Array.prototype.slice.call(thumbnails || []);
          var mediaData = [];
          if (mediaDataNode && mediaDataNode.textContent) {
            try {
              mediaData = JSON.parse(mediaDataNode.textContent) || [];
            } catch (e) {
              mediaData = [];
            }
          }

          var mediaButtons = thumbnailButtons.slice();
          if (!mediaButtons.length && mediaData.length) {
            mediaButtons = mediaData.map(function(item) {
              return {
                __vsoVirtual: true,
                __active: false,
                mediaId: String(item.id || ''),
                src: item.src || '',
                alt: item.alt || ''
              };
            });
          }

          var activeMediaIndex = 0;
          var allowVariantImageUpdates = false;
          function getMediaId(btn) {
            if (!btn) return '';
            if (btn.__vsoVirtual) return btn.mediaId || '';
            return btn.getAttribute('data-media-id') || '';
          }

          function getMediaSrc(btn) {
            if (!btn) return '';
            if (btn.__vsoVirtual) return btn.src || '';
            return btn.getAttribute('data-image-src') || '';
          }

          function getMediaAlt(btn) {
            if (!btn) return '';
            if (btn.__vsoVirtual) return btn.alt || '';
            return btn.getAttribute('data-alt') || '';
          }

          function setActiveThumbnail(mediaId) {
            var normalizedId = String(mediaId || '');
            if (thumbnailButtons.length) {
              thumbnailButtons.forEach(function(btn) {
                var isActive = btn.getAttribute('data-media-id') === normalizedId;
                btn.setAttribute('aria-current', isActive ? 'true' : 'false');
              });
            }

            for (var i = 0; i < mediaButtons.length; i++) {
              var btn = mediaButtons[i];
              var isActiveMedia = getMediaId(btn) === normalizedId;
              if (btn && btn.__vsoVirtual) btn.__active = isActiveMedia;
              if (isActiveMedia) activeMediaIndex = i;
            }

            if (counterIndexNode) counterIndexNode.textContent = String(activeMediaIndex + 1);
            if (counterTotalNode) counterTotalNode.textContent = String(mediaButtons.length || 0);
            if (mediaDotButtons.length) {
              mediaDotButtons.forEach(function(dot) {
                var idx = Number(dot.getAttribute('data-index') || 0);
                var isActiveDot = idx === activeMediaIndex;
                dot.classList.toggle('is-active', isActiveDot);
                dot.setAttribute('aria-current', isActiveDot ? 'true' : 'false');
              });
            }
          }

          function getActiveThumbnailIndex() {
            if (thumbnailButtons.length) {
              for (var i = 0; i < thumbnailButtons.length; i++) {
                if (thumbnailButtons[i].getAttribute('aria-current') === 'true') return i;
              }
              return 0;
            }
            return activeMediaIndex || 0;
          }

          function activateThumbnailAt(index, direction) {
            if (!mediaButtons.length) return;
            var normalizedIndex = ((index % mediaButtons.length) + mediaButtons.length) % mediaButtons.length;
            var btn = mediaButtons[normalizedIndex];
            if (!btn) return;
            var src = getMediaSrc(btn);
            var mediaId = getMediaId(btn);
            var alt = getMediaAlt(btn);
            transitionMainImage(src, mediaId, direction || 0);
            if (alt) {
              if (mainImage) mainImage.setAttribute('alt', alt);
              var entering = mainMediaContainer?.querySelector('img.vso-product-info__main-image.is-entering');
          if (entering) entering.setAttribute('alt', alt);
        }
            if (btn && !btn.__vsoVirtual && typeof btn.scrollIntoView === 'function') {
              btn.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
            }
            window.setTimeout(function() {
              if (btn && !btn.__vsoVirtual) nudgeThumbnailsAfterSelection(btn);
            }, 120);
          }

      function getReduceMotion() {
        try {
          return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        } catch (e) {
          return false;
        }
      }

      function cleanupTransitionImages(keepNode) {
        if (!mainMediaContainer) return;
        var imgs = mainMediaContainer.querySelectorAll('img.vso-product-info__main-image');
        imgs.forEach(function(img) {
          if (keepNode && img === keepNode) return;
          if (img === mainImage) return;
          if (img.classList.contains('is-entering') || img.classList.contains('is-exiting')) {
            img.remove();
          }
        });
      }

      function transitionMainImage(src, mediaId, direction) {
        if (!src) return;
        if (!mainMediaContainer) return;

        if (!mainImage) {
          mainImage = mainMediaContainer.querySelector('img.vso-product-info__main-image') || mainMediaContainer.querySelector('img');
        }

        if (!mainImage) return;

        if (mainImage.getAttribute('src') === src) {
          if (mediaId) setActiveThumbnail(mediaId);
          return;
        }

        if (getReduceMotion()) {
          mainImage.setAttribute('src', src);
          mainImage.removeAttribute('srcset');
          mainImage.removeAttribute('sizes');
          if (mediaId) setActiveThumbnail(mediaId);
          return;
        }

        cleanupTransitionImages();

        var nextImg = document.createElement('img');
        nextImg.className = 'vso-product-info__main-image is-entering';
        nextImg.setAttribute('src', src);
        nextImg.setAttribute('alt', mainImage.getAttribute('alt') || '');
        nextImg.setAttribute('loading', 'eager');
        nextImg.setAttribute('decoding', 'async');
        nextImg.removeAttribute('srcset');
        nextImg.removeAttribute('sizes');
        nextImg.setAttribute('data-vso-main-image', '');

        var isSlide = direction !== 0;
        if (isSlide) {
          var enterX = direction > 0 ? '100%' : '-100%';
          var exitX = direction > 0 ? '-100%' : '100%';
          nextImg.style.setProperty('--vso-enter-x', enterX);
          mainImage.style.setProperty('--vso-exit-x', exitX);
          nextImg.classList.add('is-slide');
          mainImage.classList.add('is-slide');
        } else {
          nextImg.style.setProperty('--vso-enter-x', '0%');
          mainImage.style.setProperty('--vso-exit-x', '0%');
          nextImg.classList.add('is-fade');
          mainImage.classList.add('is-fade');
        }

        mainMediaContainer.appendChild(nextImg);

        // Start transition next frame
        window.requestAnimationFrame(function() {
          // Some browsers need a second frame to pick up initial styles
          window.requestAnimationFrame(function() {
            mainImage.classList.remove('is-entering');
            mainImage.classList.add('is-exiting');
            nextImg.classList.remove('is-entering');
            nextImg.classList.add('is-active');
          });
        });

        var didFinish = false;
        function finish() {
          if (didFinish) return;
          didFinish = true;
          try {
            mainImage.remove();
          } catch (e) {}
          mainImage = nextImg;
          mainImage.classList.remove('is-entering', 'is-exiting', 'is-slide', 'is-fade');
          mainImage.classList.add('is-active');
          cleanupTransitionImages(mainImage);
          if (mediaId) setActiveThumbnail(mediaId);
        }

        nextImg.addEventListener('transitionend', finish, { once: true });
        window.setTimeout(finish, 350);

        preloadAdjacentImages();
      }

      var preloadCache = {};
      function preloadImage(src) {
        if (!src || preloadCache[src]) return;
        preloadCache[src] = true;
        var img = new Image();
        img.src = src;
      }

      function preloadAdjacentImages() {
        if (!mediaButtons.length || mediaButtons.length <= 1) return;
        var current = activeMediaIndex;
        var prevIdx = ((current - 1) % mediaButtons.length + mediaButtons.length) % mediaButtons.length;
        var nextIdx = (current + 1) % mediaButtons.length;
        preloadImage(getMediaSrc(mediaButtons[prevIdx]));
        preloadImage(getMediaSrc(mediaButtons[nextIdx]));
      }

          thumbnailButtons.forEach(function(btn) {
            if (!btn || !btn.addEventListener) return;
            btn.addEventListener('click', function() {
              var src = btn.getAttribute('data-image-src');
              var mediaId = btn.getAttribute('data-media-id');
              var alt = btn.getAttribute('data-alt');
              var currentIndex = getActiveThumbnailIndex();
              var nextIndex = mediaButtons.indexOf(btn);
              var direction = 0;
              if (nextIndex > currentIndex) direction = 1;
              if (nextIndex < currentIndex) direction = -1;
              transitionMainImage(src, mediaId, direction);
          if (alt) {
            if (mainImage) mainImage.setAttribute('alt', alt);
            if (mainMediaContainer) {
              var entering = mainMediaContainer.querySelector('img.vso-product-info__main-image.is-entering');
              if (entering) entering.setAttribute('alt', alt);
            }
          }
              window.setTimeout(function() {
                nudgeThumbnailsAfterSelection(btn);
              }, 0);
