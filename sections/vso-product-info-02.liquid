      #shopify-section-{{ section.id }} .vso-product-info__testimonial-card--glare::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 60%;
        height: 100%;
        transform: translateX(-140%) skewX(-20deg);
        background: linear-gradient(
          120deg,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.45) 50%,
          rgba(255, 255, 255, 0) 100%
        );
        pointer-events: none;
        animation: vsoProductInfoTestimonialGlare 5s ease-in-out infinite;
      }

      @keyframes vsoProductInfoTestimonialGlare {
        0% {
          transform: translateX(-140%) skewX(-20deg);
          opacity: 0;
        }
        10% {
          opacity: 1;
        }
        35% {
          transform: translateX(260%) skewX(-20deg);
          opacity: 1;
        }
        40% {
          opacity: 0;
          transform: translateX(260%) skewX(-20deg);
        }
        100% {
          opacity: 0;
          transform: translateX(260%) skewX(-20deg);
        }
      }

