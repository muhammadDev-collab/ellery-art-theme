                                <span class="vso-product-info__collapsible-leading-icon" aria-hidden="true">
                                  {{
                                    block.settings.icon_image
                                    | image_url: width: 64
                                    | image_tag: loading: 'lazy', alt: ''
                                  }}
                                </span>
                              {%- endif -%}
                              <span class="vso-product-info__collapsible-title">
                                {{ block.settings.title | default: 'Details' | escape }}
                              </span>
                            </span>
                            <span class="vso-product-info__collapsible-icon icon-plus" aria-hidden="true">
                              <span class="svg-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none"><line class="horizontal" x1="0" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="1"/><line class="vertical" x1="8" y1="0" x2="8" y2="16" stroke="currentColor" stroke-width="1"/></svg>
                              </span>
                            </span>
                          </div>
                          <div class="vso-product-info__collapsible-content" id="{{ vso_collapsible_answer_id }}" data-vso-collapsible-answer>
                            <div class="vso-product-info__collapsible-content-inner rte">
                              {{ block.settings.content }}
                            </div>
                          </div>
