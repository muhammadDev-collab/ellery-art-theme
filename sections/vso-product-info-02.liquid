          if (optionValueInputs.length) {
            optionValueInputs.forEach(function(input) {
              input.addEventListener('change', function() {
                allowVariantImageUpdates = true;
                syncFromOptionInputs();
                updateSelectedLabels();
              });
            });
            syncFromOptionInputs();
          }

          if (optionDropdowns.length) {
            optionDropdowns.forEach(function(dropdown) {
              dropdown.addEventListener('change', function() {
                allowVariantImageUpdates = true;
                syncFromOptionInputs();
              });
            });
            syncFromOptionInputs();
          }

          function initCollapsibles() {
            var collapsibleItems = Array.prototype.slice.call(sectionRoot.querySelectorAll('[data-vso-collapsible-item]') || []);
            if (!collapsibleItems.length) return;

            function closeItem(item) {
              var question = item.querySelector('[data-vso-collapsible-question]');
              var answer = item.querySelector('[data-vso-collapsible-answer]');
              if (!answer) return;
              if (!item.classList.contains('is-open')) {
                if (question) question.setAttribute('aria-expanded', 'false');
                answer.style.height = '0px';
                return;
              }

              item.classList.remove('is-open');
              if (question) question.setAttribute('aria-expanded', 'false');

              var currentHeight = answer.scrollHeight;
              answer.style.height = currentHeight + 'px';
              answer.offsetHeight;
              answer.style.height = '0px';
            }

            function closeAll(except) {
              collapsibleItems.forEach(function(item) {
                if (except && item === except) return;
                closeItem(item);
              });
            }

            function openItem(item) {
              var question = item.querySelector('[data-vso-collapsible-question]');
              var answer = item.querySelector('[data-vso-collapsible-answer]');
              if (!answer) return;

              closeAll(item);
              item.classList.add('is-open');
              if (question) question.setAttribute('aria-expanded', 'true');

              if (answer.style.height === 'auto') answer.style.height = answer.scrollHeight + 'px';
              answer.style.height = '0px';
              answer.offsetHeight;
              answer.style.height = answer.scrollHeight + 'px';

              answer.addEventListener('transitionend', function onEnd(e) {
                if (e.propertyName !== 'height') return;
                answer.removeEventListener('transitionend', onEnd);
                if (item.classList.contains('is-open')) answer.style.height = 'auto';
              });
            }

            function toggleItem(item) {
              if (item.classList.contains('is-open')) {
                closeItem(item);
              } else {
                openItem(item);
              }
            }

            collapsibleItems.forEach(function(item) {
              var question = item.querySelector('[data-vso-collapsible-question]');
              var answer = item.querySelector('[data-vso-collapsible-answer]');
              if (!question || !answer) return;

              item.classList.remove('is-open');
              question.setAttribute('aria-expanded', 'false');
              answer.style.height = '0px';

              if (!question.__vsoCollapsibleBound) {
                question.__vsoCollapsibleBound = true;
                question.addEventListener('click', function() {
                  toggleItem(item);
                });
                question.addEventListener('keydown', function(e) {
                  if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    toggleItem(item);
                  }
                });
              }
            });
          }

          initCollapsibles();
        })();
      </script>
    {%- endif -%}

