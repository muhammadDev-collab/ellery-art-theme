{%- endcomment -%}

{%- liquid
  assign vso_product = section.settings.product
  if vso_product == blank and product != blank
    assign vso_product = product
  endif

  assign vso_current_variant = blank
  if vso_product != blank
    assign vso_current_variant = vso_product.selected_or_first_available_variant
    if vso_current_variant == blank
      assign vso_current_variant = vso_product.variants.first
    endif
  endif

  assign vso_media_block = section.blocks | where: 'type', 'media' | first

  assign vso_pagination_type = vso_media_block.settings.pagination_type | default: 'thumbnails'

  assign vso_show_arrows_desktop = true
  if vso_media_block != blank and vso_media_block.settings.show_arrows_desktop != nil
    assign vso_show_arrows_desktop = vso_media_block.settings.show_arrows_desktop
  endif

  assign vso_has_thumbnails = false
  if vso_pagination_type == 'thumbnails' and vso_product != blank and vso_product.media.size > 1
    assign vso_has_thumbnails = true
  endif

  assign vso_thumbnails_position_desktop = vso_media_block.settings.thumbnails_position_desktop | default: 'side'
  assign vso_thumbnails_side_desktop = false
  if vso_has_thumbnails and vso_thumbnails_position_desktop == 'side'
    assign vso_thumbnails_side_desktop = true
  endif

  assign vso_layout_class = 'vso-product-info--media-left'

  assign vso_title_block = section.blocks | where: 'type', 'title' | first
  assign vso_meta_block = section.blocks | where: 'type', 'meta' | first
  assign vso_price_block = section.blocks | where: 'type', 'price' | first
  assign vso_variant_picker_block = section.blocks | where: 'type', 'variant_picker' | first
  assign vso_form_block = section.blocks | where: 'type', 'form' | first
  assign vso_description_block = section.blocks | where: 'type', 'description' | first

  assign vso_title_custom_typography = false
  assign vso_title_size = 34
  assign vso_title_size_mobile = 26
  assign vso_title_weight = 700
  assign vso_title_line_height = 115
  assign vso_title_alignment = 'left'
  assign vso_title_alignment_mobile = 'left'
  assign vso_title_color = '#111111'
  if vso_title_block != blank
    assign vso_title_custom_typography = vso_title_block.settings.title_custom_typography | default: false
    if vso_title_custom_typography
      assign vso_title_size = vso_title_block.settings.title_size | default: 34
      assign vso_title_size_mobile = vso_title_block.settings.title_size_mobile | default: 26
      assign vso_title_weight = vso_title_block.settings.title_weight | default: 700
      assign vso_title_line_height = vso_title_block.settings.title_line_height | default: 115
      assign vso_title_alignment = vso_title_block.settings.title_alignment | default: 'left'
      assign vso_title_alignment_mobile = vso_title_block.settings.title_alignment_mobile | default: 'left'
      assign vso_title_color = vso_title_block.settings.title_color | default: '#111111'
    endif
  endif

  assign vso_meta_color = '#6b6b6b'
  if vso_meta_block != blank
    assign vso_meta_color = vso_meta_block.settings.meta_color | default: '#6b6b6b'
  endif

  assign vso_price_size = 24
  assign vso_price_size_mobile = 20
  assign vso_price_weight = 700
  assign vso_price_color = '#111111'
  assign vso_compare_price_color = '#6b6b6b'
  if vso_price_block != blank
    assign vso_price_size = vso_price_block.settings.price_size | default: 24
    assign vso_price_size_mobile = vso_price_block.settings.price_size_mobile | default: 20
    assign vso_price_weight = vso_price_block.settings.price_weight | default: 700
    assign vso_price_color = vso_price_block.settings.price_color | default: '#111111'
    assign vso_compare_price_color = vso_price_block.settings.compare_price_color | default: '#6b6b6b'
  endif

  assign vso_input_border_radius = 10
  assign vso_input_text_color = '#111111'
  assign vso_selected_background = '#111111'
  assign vso_box_background = '#ffffff'
  assign vso_box_text_color = '#111111'
  assign vso_box_border_color = '#d9d9d9'
  assign vso_box_selected_background = '#111111'
  assign vso_box_selected_text_color = '#ffffff'
  assign vso_dropdown_border_color = '#d9d9d9'
  if vso_variant_picker_block != blank
    assign vso_input_border_radius = vso_variant_picker_block.settings.input_border_radius | default: 10
    assign vso_input_text_color = vso_variant_picker_block.settings.input_text_color | default: '#111111'
    assign vso_selected_background = vso_variant_picker_block.settings.selected_background | default: '#111111'
    assign vso_box_background = vso_variant_picker_block.settings.box_background | default: '#ffffff'
    assign vso_box_text_color = vso_variant_picker_block.settings.box_text_color | default: '#111111'
    assign vso_box_border_color = vso_variant_picker_block.settings.box_border_color | default: '#d9d9d9'
    assign vso_box_selected_background = vso_variant_picker_block.settings.box_selected_background | default: '#111111'
    assign vso_box_selected_text_color = vso_variant_picker_block.settings.box_selected_text_color | default: '#ffffff'
    assign vso_dropdown_border_color = vso_variant_picker_block.settings.dropdown_border_color | default: '#d9d9d9'
  endif

  assign vso_qty_border_color = '#d9d9d9'
  assign vso_qty_border_radius = 10
  assign vso_qty_background_color = '#ffffff'
  assign vso_qty_text_color = '#111111'

  assign vso_button_background = '#111111'
  assign vso_button_text_color = '#ffffff'
  assign vso_button_text_weight = 600
  assign vso_button_font_size = 15
  assign vso_button_font_size_mobile = 15
  assign vso_button_custom_font = false
  assign vso_button_border_radius = 12
  assign vso_button_border_width = 1
  assign vso_button_border_color = '#e0e0e0'
  if vso_form_block != blank
    assign vso_qty_border_color = vso_form_block.settings.qty_border_color | default: '#d9d9d9'
    assign vso_qty_border_radius = vso_form_block.settings.qty_border_radius | default: 10
    assign vso_qty_background_color = vso_form_block.settings.qty_background_color | default: '#ffffff'
    assign vso_qty_text_color = vso_form_block.settings.qty_text_color | default: '#111111'
    assign vso_button_background = vso_form_block.settings.button_background | default: '#111111'
    assign vso_button_text_color = vso_form_block.settings.button_text_color | default: '#ffffff'
    assign vso_button_text_weight = vso_form_block.settings.button_text_weight | default: 600
    assign vso_button_font_size = vso_form_block.settings.button_font_size | default: 15
    assign vso_button_font_size_mobile = vso_form_block.settings.button_font_size_mobile | default: 15
    assign vso_button_custom_font = vso_form_block.settings.button_custom_font
    assign vso_button_border_radius = vso_form_block.settings.button_border_radius | default: 12
    assign vso_button_border_width = vso_form_block.settings.button_border_width | default: 1
    assign vso_button_border_color = vso_form_block.settings.button_border_color | default: '#e0e0e0'
    assign vso_dc_background = vso_form_block.settings.dc_background | default: '#111111'
    assign vso_dc_text_color = vso_form_block.settings.dc_text_color | default: '#ffffff'
    assign vso_dc_border_radius = vso_form_block.settings.dc_border_radius | default: 12
    assign vso_dc_border_width = vso_form_block.settings.dc_border_width | default: 0
    assign vso_dc_border_color = vso_form_block.settings.dc_border_color | default: '#e0e0e0'
    assign vso_dc_font_size = vso_form_block.settings.dc_font_size | default: 15
    assign vso_dc_font_weight = vso_form_block.settings.dc_font_weight | default: 600
    assign vso_button_padding_vertical = vso_form_block.settings.button_padding_vertical | default: 12
  endif

  assign vso_description_color = '#111111'
  assign vso_description_font_size = 14
  assign vso_description_font_size_mobile = 14
  assign vso_description_font_weight = 400
  assign vso_description_custom_font = false
  if vso_description_block != blank
    assign vso_description_color = vso_description_block.settings.description_color | default: '#111111'
    assign vso_description_font_size = vso_description_block.settings.description_font_size | default: 14
    assign vso_description_font_size_mobile = vso_description_block.settings.description_font_size_mobile | default: 14
    assign vso_description_font_weight = vso_description_block.settings.description_font_weight | default: 400
    assign vso_description_custom_font = vso_description_block.settings.description_custom_font
  endif

  assign vso_media_testimonial_block = section.blocks | where: 'type', 'media_testimonial' | first
  assign vso_media_benefits_block = section.blocks | where: 'type', 'benefits' | first
  assign vso_media_benefits_has_content = false
  if vso_media_benefits_block != blank
    if vso_media_benefits_block.settings.icon_1 != blank or vso_media_benefits_block.settings.text_1 != blank
      assign vso_media_benefits_has_content = true
    elsif vso_media_benefits_block.settings.icon_2 != blank or vso_media_benefits_block.settings.text_2 != blank
      assign vso_media_benefits_has_content = true
    elsif vso_media_benefits_block.settings.icon_3 != blank or vso_media_benefits_block.settings.text_3 != blank
      assign vso_media_benefits_has_content = true
    endif
  endif
-%}

    {%- style -%}
  .vd-l { display: none !important; }
      #shopify-section-{{ section.id }} {
        margin-top: {{ section.settings.margin_top }}px;
        margin-bottom: {{ section.settings.margin_bottom }}px;
        --vso-margin-top-mobile: {{ section.settings.margin_top_mobile | default: 0 }}px;
        --vso-margin-bottom-mobile: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
        --vso-section-background: {% if section.settings.background_type == 'gradient' %}{{ section.settings.background_gradient }}{% else %}{{ section.settings.background_color }}{% endif %};
        --vso-collapsible-style: {{ section.settings.collapsible_style | default: 'line' }};
        --vso-collapsible-title-color: {{ section.settings.collapsible_title_color | default: '#111111' }};
        --vso-collapsible-title-size: {{ section.settings.collapsible_title_size | default: 14 }}px;
        --vso-collapsible-title-size-mobile: {{ section.settings.collapsible_title_size_mobile | default: 14 }}px;
        --vso-collapsible-title-weight: {{ section.settings.collapsible_title_weight | default: 500 }};
        --vso-collapsible-content-color: {{ section.settings.collapsible_content_color | default: '#111111' }};
        --vso-collapsible-content-size: {{ section.settings.collapsible_content_size | default: 14 }}px;
        --vso-collapsible-content-size-mobile: {{ section.settings.collapsible_content_size_mobile | default: 14 }}px;
        --vso-collapsible-leading-icon-gap: {{ section.settings.collapsible_leading_icon_gap | default: 10 }}px;
        --vso-collapsible-icon-size: {{ section.settings.collapsible_icon_size | default: 18 }}px;
        --vso-collapsible-pill-background: {{ section.settings.collapsible_background_color | default: '#f7f7f7' }};
        --vso-collapsible-pill-radius: {{ section.settings.collapsible_border_radius | default: 14 }}px;
        --vso-media-dot-active: {{ vso_media_block.settings.dots_active_color | default: '#111111' }};
        --vso-media-dot-inactive: {{ vso_media_block.settings.dots_inactive_color | default: '#d9d9d9' }};
        --vso-media-dot-pill-bg: {{ vso_media_block.settings.dots_pill_background_color | default: '#ffffff' }};
        --vso-media-fixed-height: {{ vso_media_block.settings.media_fixed_height | default: 560 }}px;
        --vso-media-fixed-height-mobile: {{ vso_media_block.settings.media_fixed_height_mobile | default: 420 }}px;
        {% if section.settings.background_type == 'gradient' %}
          background: {{ section.settings.background_gradient }};
        {% else %}
          background-color: {{ section.settings.background_color }};
        {% endif %}
      }

      @media screen and (max-width: 749px) {
        #shopify-section-{{ section.id }} {
          margin-top: var(--vso-margin-top-mobile);
          margin-bottom: var(--vso-margin-bottom-mobile);
        }
      }

  #shopify-section-{{ section.id }} .vso-product-info__container {
    max-width: calc(var(--page-content-width, var(--page-width, 1440px)) + (var(--page-margin, 16px) * 2));
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    box-sizing: border-box;
    padding-left: var(--page-margin, 16px);
    padding-right: var(--page-margin, 16px);
  }

  {%- if section.settings.enable_advanced_settings -%}
    #shopify-section-{{ section.id }} .vso-product-info__container {
      max-width: {{ section.settings.max_width }}rem;
      padding-left: {{ section.settings.padding_x_mobile }}px;
      padding-right: {{ section.settings.padding_x_mobile }}px;
    }

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .vso-product-info__container {
        padding-left: {{ section.settings.padding_x }}px;
        padding-right: {{ section.settings.padding_x }}px;
      }
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .vso-product-info__grid {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.grid_gap_mobile }}px;
    align-items: stretch;
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .vso-product-info__grid {
      display: grid;
      grid-template-columns: minmax(0, {{ vso_media_block.settings.media_width_desktop | default: 60 }}%) minmax(0, 1fr);
      gap: {{ section.settings.grid_gap }}px;
      align-items: start;
    }

  }

      #shopify-section-{{ section.id }} .vso-product-info__card {
        border-radius: 0;
        overflow: hidden;
        background: var(--vso-section-background);
      }

  #shopify-section-{{ section.id }} .vso-product-info__card-inner {
    padding: 0;
  }

  #shopify-section-{{ section.id }} .vso-product-info__details .vso-product-info__card-inner > * + * {
    margin-top: 10px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-product-info__card-inner {
      padding: 0;
    }
  }

  #shopify-section-{{ section.id }} .vso-product-info__media {
    display: flex;
    flex-direction: column;
    gap: {{ vso_media_block.settings.media_gap | default: 12 }}px;
    width: 100%;
  }

  {%- if vso_media_block.settings.media_sticky_desktop -%}
    @media screen and (min-width: 990px) {
      #shopify-section-{{ section.id }} .vso-product-info__media {
        position: sticky;
        top: var(--header-height, 0px);
        align-self: start;
      }
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .vso-product-info__media-layout {
    display: flex;
    flex-direction: column;
    --vso-media-layout-gap: 12px;
    gap: var(--vso-media-layout-gap);
  }

  #shopify-section-{{ section.id }} .vso-product-info__thumbnails-wrap {
    order: 1;
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-main {
    order: 0;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-product-info__media-layout {
      --vso-media-layout-gap: 16px;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout.vso-product-info__media-layout--side {
      flex-direction: row;
      align-items: flex-start;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--side .vso-product-info__thumbnails-wrap {
      order: 0;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--side .vso-product-info__media-main {
      order: 1;
    }
  }

      #shopify-section-{{ section.id }} .vso-product-info__media-main {
        position: relative;
        width: 100%;
        overflow: hidden;
        border-radius: {{ vso_media_block.settings.thumbnail_border_radius | default: 10 }}px;
        background: rgba(0, 0, 0, 0.03);
        touch-action: pan-y;
      }

      #shopify-section-{{ section.id }} .vso-product-info__media-main[data-vso-fixed-height='true'] {
        height: var(--vso-media-fixed-height-mobile);
      }
    
      @media screen and (min-width: 750px) {
        #shopify-section-{{ section.id }} .vso-product-info__media-main[data-vso-fixed-height='true'] {
          height: var(--vso-media-fixed-height);
        }
      }
    
      #shopify-section-{{ section.id }} .vso-product-info__media-main::before {
        content: '';
        display: block;
        padding-bottom: var(--vso-media-padding-bottom, 100%);
      }
    
      #shopify-section-{{ section.id }} .vso-product-info__media-main[data-vso-fixed-height='true']::before {
        padding-bottom: 0;
      }

  #shopify-section-{{ section.id }} .vso-product-info__media-main > img,
  #shopify-section-{{ section.id }} .vso-product-info__media-main > svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-benefits {
    display: flex;
    flex-direction: column;
    gap: var(--vso-media-benefits-gap, 12px);
    margin-top: 12px;
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-benefit-item {
    background: var(--vso-media-benefit-bg, #f1efec);
    border: var(--vso-media-benefit-border-width, 0px) solid var(--vso-media-benefit-border-color, transparent);
    border-radius: var(--vso-media-benefit-radius, 20px);
    padding: var(--vso-media-benefit-padding, 16px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--vso-media-benefit-icon-gap, 10px);
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-benefit-icon {
    width: var(--vso-media-benefit-icon-size, 32px);
    height: var(--vso-media-benefit-icon-size, 32px);
    min-width: var(--vso-media-benefit-icon-size, 32px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--vso-media-benefit-icon-color, #0f4b5a);
    line-height: 0;
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-benefit-icon img,
  #shopify-section-{{ section.id }} .vso-product-info__media-benefit-icon svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-benefit-icon svg {
    fill: currentColor;
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-benefit-text {
    margin: 0;
    color: var(--vso-media-benefit-text-color, #0f4b5a);
    font-size: var(--vso-media-benefit-text-size-mobile, 14px);
    line-height: var(--vso-media-benefit-line-height, 1.35);
    font-weight: var(--vso-media-benefit-text-weight, 600);
  }

  #shopify-section-{{ section.id }} .vso-product-info__media-benefit-text p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-product-info__media-benefit-text {
      font-size: var(--vso-media-benefit-text-size, 15px);
    }
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits {
      display: grid;
      grid-template-columns: minmax(0, 1fr) var(--vso-media-benefits-width, 100px);
      grid-template-rows: auto auto;
      column-gap: var(--vso-media-layout-gap, 10px);
      row-gap: 10px;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits .vso-product-info__media-main {
      grid-column: 1;
      grid-row: 1;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits .vso-product-info__media-benefits {
      grid-column: 2;
      grid-row: 1;
      margin-top: 0;
      align-self: stretch;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits .vso-product-info__media-benefit-item {
      flex: 1 1 0;
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits .vso-product-info__thumbnails-wrap {
      grid-column: 1 / -1;
      grid-row: 2;
      width: 100%;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits .vso-product-info__thumbnails {
      flex-direction: row;
      max-height: none;
      overflow-x: auto;
      overflow-y: hidden;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--benefits-hidden-mobile {
      display: flex;
      flex-direction: column;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--benefits-hidden-mobile .vso-product-info__media-benefits {
      display: none;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--benefits-hidden-mobile .vso-product-info__media-main {
      order: 0;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--benefits-hidden-mobile .vso-product-info__thumbnails-wrap {
      order: 1;
      width: 100%;
      max-width: 100%;
    }
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--side {
      display: flex;
      flex-direction: row;
      align-items: stretch;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--side .vso-product-info__media-main {
      flex: 1 1 auto;
      min-width: 0;
      order: 1;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--side.vso-product-info__media-layout--has-thumbnails .vso-product-info__thumbnails-wrap {
      order: 0;
      width: var(--vso-thumbs-width, 88px);
      max-width: var(--vso-thumbs-width, 88px);
      flex: 0 0 auto;
    }

    #shopify-section-{{ section.id }} .vso-product-info__media-layout--with-benefits.vso-product-info__media-layout--side.vso-product-info__media-layout--has-thumbnails .vso-product-info__thumbnails {
      flex-direction: column;
      gap: 16px;
