      #shopify-section-{{ section.id }} .vso-product-info__collapsible--pill:last-child {
        margin-bottom: 0;
      }
    
              #shopify-section-{{ section.id }} .vso-product-info__collapsible-summary {
                position: relative;
                padding: 14px 0;
                cursor: pointer;
                user-select: none;
                display: flex;
