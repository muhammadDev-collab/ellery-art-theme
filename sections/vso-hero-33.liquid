        { "type": "inline_richtext", "id": "title", "label": "Title", "default": "Feature Title" },
        { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Feature description goes here.</p>" }
      ]
    }
  ],
  "presets": [
    {
