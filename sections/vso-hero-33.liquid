    { "type": "range", "id": "features_gap_mobile", "label": "Mobile gap between features", "min": 16, "max": 48, "step": 4, "unit": "px", "default": 32, "visible_if": "{{ section.settings.enable_advanced_settings == true }}" },

    { "type": "header", "content": "Section Padding" },
