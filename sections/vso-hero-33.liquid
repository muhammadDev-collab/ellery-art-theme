        { "type": "range", "id": "media_margin_top_mobile", "label": "Mobile margin top", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 0 },
        { "type": "range", "id": "media_margin_bottom_mobile", "label": "Mobile margin bottom", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 0 }
      ]
    },
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "header", "content": "Feature Settings" },
        { "type": "select", "id": "position", "label": "Position", "options": [
          { "value": "left", "label": "Left side" },
          { "value": "right", "label": "Right side" }
        ], "default": "left" },
