    { "type": "select", "id": "feature_description_as", "label": "Render as", "options": [
      { "value": "h2", "label": "H2" },
      { "value": "h3", "label": "H3" },
      { "value": "h4", "label": "H4" },
      { "value": "h5", "label": "H5" },
      { "value": "p", "label": "Paragraph (p)" }
    ], "default": "p", "visible_if": "{{ section.settings.feature_description_custom_font == false }}" },
    { "type": "font_picker", "id": "feature_description_font", "label": "Font family", "default": "poppins_n4", "visible_if": "{{ section.settings.feature_description_custom_font }}" },
    { "type": "range", "id": "feature_description_size_desktop", "label": "Desktop text size", "min": 12, "max": 20, "step": 1, "unit": "px", "default": 15, "visible_if": "{{ section.settings.feature_description_custom_font }}" },
