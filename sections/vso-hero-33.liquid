            "title": "Long Lasting",
            "description": "<p>Premium products that deliver exceptional value and performance.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "position": "right",
            "title": "Fresh Scent",
            "description": "<p>Subtle, masculine fragrance that lasts throughout the day.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
