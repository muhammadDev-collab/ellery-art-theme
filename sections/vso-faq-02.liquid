{% endcomment %}

{% liquid
  assign enable_advanced_settings = false
  if section.settings.enable_advanced_settings == true
    assign enable_advanced_settings = true
  endif

  assign desktop_column_gap = section.settings.desktop_column_gap
  assign section_full_width = section.settings.section_full_width
  assign section_max_width_desktop = section.settings.section_max_width_desktop
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign left_column_padding_right_desktop = section.settings.left_column_padding_right_desktop
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_top_mobile = section.settings.margin_top_mobile
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile
  assign faq_item_gap = section.settings.faq_item_gap
  assign faq_question_color = section.settings.faq_question_color
  assign faq_question_font_size = section.settings.faq_question_font_size
  assign faq_question_font_size_mobile = section.settings.faq_question_font_size_mobile
  assign faq_question_font_weight = section.settings.faq_question_font_weight
  assign faq_question_padding_vertical = section.settings.faq_question_padding_vertical
  assign faq_question_padding_vertical_mobile = section.settings.faq_question_padding_vertical_mobile
  assign faq_question_custom_font = section.settings.faq_question_custom_font
  assign faq_question_as = section.settings.faq_question_as
  assign faq_answer_color = section.settings.faq_answer_color
  assign faq_answer_font_size = section.settings.faq_answer_font_size
  assign faq_answer_font_size_mobile = section.settings.faq_answer_font_size_mobile
  assign faq_answer_custom_font = section.settings.faq_answer_custom_font
  assign faq_divider_width = section.settings.faq_divider_width

  if enable_advanced_settings
    assign faq_icon_size = section.settings.faq_icon_size
    assign faq_icon_color = section.settings.faq_icon_color
  else
    assign faq_icon_size = 18
  assign faq_icon_color = faq_question_color
  endif

  assign title_block = section.blocks | where: "type", "title" | first
  assign subtitle_block = section.blocks | where: "type", "subtitle" | first
  assign team_block = section.blocks | where: "type", "team" | first
-%}
  
  {% style %}
  .vd-l { display: none !important; }
    #shopify-section-{{ section.id }} {
      --section-border-radius: 0px;
      --section-horizontal-padding: var(--page-margin, 16px);
      background: transparent;
      margin-top: {{ margin_top_mobile }}px;
      margin-bottom: {{ margin_bottom_mobile }}px;
      border-radius: var(--section-border-radius);
      overflow: hidden;
      padding: 0;
    }

    {% if enable_advanced_settings %}
      #shopify-section-{{ section.id }} {
        --section-horizontal-padding: {{ padding_horizontal_mobile }}px;
      }
    {% endif %}

    @media screen and (max-width: 990px) {
      #shopify-section-{{ section.id }} {
        {% if section.settings.section_bg_type == 'gradient' %}
          background: {{ section.settings.section_bg_gradient }};
        {% else %}
          background-color: {{ section.settings.section_bg_color }};
        {% endif %}
      }
    }

    @media screen and (min-width: 991px) {
      #shopify-section-{{ section.id }} {
        {% if section.settings.full_width_desktop %}
          --section-border-radius: 0px;
        {% else %}
          --section-border-radius: {{ section.settings.section_border_radius }}px;
        {% endif %}
        --section-horizontal-padding: 0px;
        margin-top: {{ margin_top }}px;
        margin-bottom: {{ margin_bottom }}px;
        border-radius: var(--section-border-radius);
        {% if section.settings.full_width_desktop %}
          {% if section.settings.section_bg_type == 'gradient' %}
            background: {{ section.settings.section_bg_gradient }};
          {% else %}
            background-color: {{ section.settings.section_bg_color }};
          {% endif %}
        {% else %}
          background: transparent;
        {% endif %}
      }
    }

    {% if enable_advanced_settings == false and section.settings.full_width_desktop == false %}
      @media screen and (min-width: 991px) {
        #shopify-section-{{ section.id }} {
          --section-horizontal-padding: 40px;
        }
      }
    {% endif %}

    {% if enable_advanced_settings == false and section.settings.full_width_desktop %}
      @media screen and (min-width: 991px) {
        #shopify-section-{{ section.id }} {
          --section-container-max-width: var(--page-content-width, var(--page-width, 1440px));
          --section-outer-gutter: max(0px, calc((100vw - var(--section-container-max-width)) / 2));
          --section-horizontal-padding: max(0px, calc(var(--page-margin, 40px) - var(--section-outer-gutter)));
        }
      }
    {% endif %}

    {% if enable_advanced_settings %}
      @media screen and (min-width: 991px) {
        #shopify-section-{{ section.id }} {
          --section-horizontal-padding: {{ padding_horizontal }}px;
        }
      }
    {% endif %}

    #shopify-section-{{ section.id }} > .vso-template-faq__container {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      max-width: var(--page-content-width, var(--page-width, 1440px));
      border-radius: var(--section-border-radius);
      overflow: hidden;
      padding-left: var(--section-horizontal-padding);
      padding-right: var(--section-horizontal-padding);
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
      position: relative;
    }

    @media screen and (max-width: 990px) {
      #shopify-section-{{ section.id }} > .vso-template-faq__container {
        background: transparent;
      }
    }

    @media screen and (min-width: 991px) {
      #shopify-section-{{ section.id }} > .vso-template-faq__container {
        {% if section.settings.full_width_desktop %}
          background: transparent;
        {% else %}
          {% if section.settings.section_bg_type == 'gradient' %}
            background: {{ section.settings.section_bg_gradient }};
          {% else %}
            background-color: {{ section.settings.section_bg_color }};
          {% endif %}
        {% endif %}
        padding-top: {{ padding_top }}px;
        padding-bottom: {{ padding_bottom }}px;
      }
    }

    {% if enable_advanced_settings %}
      #shopify-section-{{ section.id }} > .vso-template-faq__container {
        {% if section_full_width %}
          max-width: none;
        {% else %}
          max-width: {{ section_max_width_desktop }}rem;
        {% endif %}
      }
    {% endif %}

    {% if section.settings.full_width_desktop == false %}
      @media screen and (min-width: 991px) {
        #shopify-section-{{ section.id }} > .vso-template-faq__container {
          width: calc(100% - (2 * var(--page-margin, 40px)));
        }
      }
    {% endif %}

    #shopify-section-{{ section.id }} .vso-faq-02__container {
      display: flex;
      width: 100%;
      gap: {{ desktop_column_gap }}px;
      align-items: flex-start;
    }

    #shopify-section-{{ section.id }} .vso-faq-02__left-column {
      flex: 0 1 40%;
      min-width: 0;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      padding-right: {{ left_column_padding_right_desktop }}px;
    }
    #shopify-section-{{ section.id }} .vso-faq-02__right-column {
      flex: 0 1 60%;
      min-width: 0;
      box-sizing: border-box;
    }
    {% if title_block %}
      #shopify-section-{{ section.id }} .vso-faq-02__title {
        text-align: {{ title_block.settings.title_alignment_desktop }};
        margin-top: {{ title_block.settings.margin_top }}px;
        margin-bottom: {{ title_block.settings.margin_bottom }}px;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__title h1,
      #shopify-section-{{ section.id }} .vso-faq-02__title h2,
      #shopify-section-{{ section.id }} .vso-faq-02__title h3,
      #shopify-section-{{ section.id }} .vso-faq-02__title h4,
      #shopify-section-{{ section.id }} .vso-faq-02__title h5,
      #shopify-section-{{ section.id }} .vso-faq-02__title p {
        margin: 0;
        color: {{ title_block.settings.title_color }};
      }
      {% if title_block.settings.custom_font %}
        #shopify-section-{{ section.id }} .vso-faq-02__title h2 {
          font-size: {{ title_block.settings.title_size }}px;
          font-weight: bold;
        }
      {% endif %}
      #shopify-section-{{ section.id }} .vso-faq-02__important-word {
        color: {{ title_block.settings.title_highlight_color }};
      }
    {% endif %}
    {% if subtitle_block %}
      #shopify-section-{{ section.id }} .vso-faq-02__subtitle {
        text-align: {{ subtitle_block.settings.subtitle_alignment_desktop }};
        margin-top: {{ subtitle_block.settings.margin_top }}px;
        margin-bottom: {{ subtitle_block.settings.margin_bottom }}px;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__subtitle h2,
      #shopify-section-{{ section.id }} .vso-faq-02__subtitle h3,
      #shopify-section-{{ section.id }} .vso-faq-02__subtitle h4,
      #shopify-section-{{ section.id }} .vso-faq-02__subtitle h5,
      #shopify-section-{{ section.id }} .vso-faq-02__subtitle p {
        margin: 0;
        color: {{ subtitle_block.settings.subtitle_color }};
      }
      {% if subtitle_block.settings.custom_font %}
        #shopify-section-{{ section.id }} .vso-faq-02__subtitle p {
          font-size: {{ subtitle_block.settings.subtitle_size }}px;
        }
      {% endif %}
    {% endif %}
    {% if team_block %}
      #shopify-section-{{ section.id }} .vso-faq-02__team {
        text-align: {{ team_block.settings.team_alignment_desktop }};
        margin-top: {{ team_block.settings.margin_top }}px;
        margin-bottom: {{ team_block.settings.margin_bottom }}px;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__team-images {
        display: flex;
        margin-bottom: {{ team_block.settings.team_images_margin_bottom }}px;
        {% if team_block.settings.team_alignment_desktop == 'left' %}
          justify-content: flex-start;
        {% elsif team_block.settings.team_alignment_desktop == 'center' %}
          justify-content: center;
        {% else %}
          justify-content: flex-end;
        {% endif %}
      }
      #shopify-section-{{ section.id }} .vso-faq-02__team-images img {
        width: {{ team_block.settings.team_image_size }}px;
        height: {{ team_block.settings.team_image_size }}px;
        border-radius: 50%;
        margin-right: -{{ team_block.settings.team_images_overlap }}px;
        border: {{ team_block.settings.team_image_border_width }}px solid {{ team_block.settings.team_image_border_color }};
        box-sizing: border-box;
        object-fit: cover;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__team-image-placeholder {
        width: {{ team_block.settings.team_image_size }}px;
        height: {{ team_block.settings.team_image_size }}px;
        border-radius: 50%;
        margin-right: -{{ team_block.settings.team_images_overlap }}px;
        border: {{ team_block.settings.team_image_border_width }}px solid {{ team_block.settings.team_image_border_color }};
        box-sizing: border-box;
        background-color: #E5E7EB;
        display: block;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph h2,
      #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph h3,
      #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph h4,
      #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph h5,
      #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph p {
        margin: 0;
        color: {{ team_block.settings.team_paragraph_color }};
      }
      {% if team_block.settings.custom_font %}
        #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph p {
          font-size: {{ team_block.settings.team_paragraph_size }}px;
        }
      {% endif %}
    {% endif %}
    #shopify-section-{{ section.id }} .vso-faq-02__faq-item {
      margin-bottom: {{ faq_item_gap }}px;
      overflow: hidden;
      border-bottom: {{ faq_divider_width }}px solid {{ faq_question_color }};
    }
    #shopify-section-{{ section.id }} .vso-faq-02__faq-question {
      position: relative;
      padding-top: {{ faq_question_padding_vertical }}px;
      padding-bottom: {{ faq_question_padding_vertical }}px;
      padding-left: 0;
      padding-right: 0;
      cursor: pointer;
      user-select: none;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 15px;
      margin: 0 !important;
      color: {{ faq_question_color }};
      background: transparent;
    }
    {% if faq_question_custom_font %}
      #shopify-section-{{ section.id }} .vso-faq-02__faq-question,
      #shopify-section-{{ section.id }} .vso-faq-02__faq-question p {
        font-size: {{ faq_question_font_size }}px;
        font-weight: {{ faq_question_font_weight }};
        margin: 0 !important;
      }
    {% endif %}
    #shopify-section-{{ section.id }} .vso-faq-02__faq-question p { margin: 0 !important; }
    #shopify-section-{{ section.id }} .vso-faq-02__faq-toggle {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      margin-top: 2px;
    }
    #shopify-section-{{ section.id }} .vso-faq-02__faq-toggle svg {
      width: {{ faq_icon_size }}px;
      height: {{ faq_icon_size }}px;
      color: {{ faq_icon_color }};
      transition: transform 0.3s ease;
    }
    #shopify-section-{{ section.id }} .vso-faq-02__faq-item.active .vso-faq-02__faq-toggle svg { transform: rotate(180deg); }
	    #shopify-section-{{ section.id }} .vso-faq-02__faq-answer {
	      height: 0;
	      overflow: hidden;
	      transition: height 0.4s ease;
	      padding-left: 0;
	      padding-right: 0;
	      background: transparent;
	    }
	    #shopify-section-{{ section.id }} .vso-faq-02__faq-item.active .vso-faq-02__faq-answer {
	    }
	    #shopify-section-{{ section.id }} .vso-faq-02__faq-answer-content {
	      color: {{ faq_answer_color }};
	      /* Keep spacing on the content so JS height calculation includes it. */
	      padding-bottom: 10px;
	    }
	    {% if faq_answer_custom_font %}
	      #shopify-section-{{ section.id }} .vso-faq-02__faq-answer-content {
	        font-size: {{ faq_answer_font_size }}px;
	      }
	    {% endif %}
	    #shopify-section-{{ section.id }} .vso-faq-02__faq-answer-content > *:first-child { margin-top: 0; }
	    #shopify-section-{{ section.id }} .vso-faq-02__faq-answer-content > *:last-child { margin-bottom: 0; }
    .vso-node { display: none; }
    .vso-node--v2 { display: block; }
    .vso-hide-on-desktop { display: none !important; }
    @media(max-width: 990px) {
      .vso-hide-on-desktop { display: flex !important; }
      #shopify-section-{{ section.id }} .vso-faq-02__container {
        flex-direction: column;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__left-column {
        display: none;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__right-column {
        display: none;
      }
      #shopify-section-{{ section.id }} .vso-faq-02__mobile-specific-order-blocks {
        flex-direction: column;
        width: 100%;
      }
      {% if title_block %}
        #shopify-section-{{ section.id }} .vso-faq-02__title {
          text-align: {{ title_block.settings.title_alignment_mobile }};
          margin-top: {{ title_block.settings.margin_top_mobile }}px;
          margin-bottom: {{ title_block.settings.margin_bottom_mobile }}px;
        }
        {% if title_block.settings.custom_font %}
          #shopify-section-{{ section.id }} .vso-faq-02__title h2 {
            font-size: {{ title_block.settings.title_size_mobile }}px;
          }
        {% endif %}
      {% endif %}
      {% if subtitle_block %}
        #shopify-section-{{ section.id }} .vso-faq-02__subtitle {
          text-align: {{ subtitle_block.settings.subtitle_alignment_mobile }};
          margin-top: {{ subtitle_block.settings.margin_top_mobile }}px;
          margin-bottom: {{ subtitle_block.settings.margin_bottom_mobile }}px;
        }
        {% if subtitle_block.settings.custom_font %}
          #shopify-section-{{ section.id }} .vso-faq-02__subtitle p {
            font-size: {{ subtitle_block.settings.subtitle_size_mobile }}px;
          }
        {% endif %}
      {% endif %}
      {% if team_block %}
        #shopify-section-{{ section.id }} .vso-faq-02__team {
          text-align: {{ team_block.settings.team_alignment_mobile }};
          margin-top: {{ team_block.settings.margin_top_mobile }}px;
          margin-bottom: {{ team_block.settings.margin_bottom_mobile }}px;
        }
        #shopify-section-{{ section.id }} .vso-faq-02__team-images {
          {% if team_block.settings.team_alignment_mobile == 'left' %}
            justify-content: flex-start;
          {% elsif team_block.settings.team_alignment_mobile == 'center' %}
            justify-content: center;
          {% else %}
            justify-content: flex-end;
          {% endif %}
        }
        {% if team_block.settings.custom_font %}
          #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph p {
            font-size: {{ team_block.settings.team_paragraph_size_mobile }}px;
          }
        {% endif %}
      {% endif %}
      #shopify-section-{{ section.id }} .vso-faq-02__faq-question {
        padding-top: {{ faq_question_padding_vertical_mobile }}px;
        padding-bottom: {{ faq_question_padding_vertical_mobile }}px;
      }
      {% if faq_question_custom_font %}
        #shopify-section-{{ section.id }} .vso-faq-02__faq-question,
        #shopify-section-{{ section.id }} .vso-faq-02__faq-question p {
          font-size: {{ faq_question_font_size_mobile }}px;
        }
      {% endif %}
      {% if faq_answer_custom_font %}
        #shopify-section-{{ section.id }} .vso-faq-02__faq-answer-content {
          font-size: {{ faq_answer_font_size_mobile }}px;
        }
      {% endif %}
    }
  {% endstyle %}
  
  {% if faq_question_custom_font %}
    <style>
      #shopify-section-{{ section.id }} .vso-faq-02__faq-question,
      #shopify-section-{{ section.id }} .vso-faq-02__faq-question p {
        font-family: {{ section.settings.faq_question_font.family }}, {{ section.settings.faq_question_font.fallback_families }};
        font-style: {{ section.settings.faq_question_font.style }};
      }
    </style>
  {% endif %}
  
  {% if faq_answer_custom_font %}
    <style>
      #shopify-section-{{ section.id }} .vso-faq-02__faq-answer-content {
        font-family: {{ section.settings.faq_answer_font.family }}, {{ section.settings.faq_answer_font.fallback_families }};
        font-style: {{ section.settings.faq_answer_font.style }};
      }
    </style>
  {% endif %}
  
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'title' %}
        {% if block.settings.custom_font %}
          <style>
            #shopify-section-{{ section.id }} .vso-faq-02__title h2 {
              font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }};
              font-style: {{ block.settings.font.style }};
            }
          </style>
        {% endif %}
      {% when 'subtitle' %}
        {% if block.settings.custom_font %}
          <style>
            #shopify-section-{{ section.id }} .vso-faq-02__subtitle {
              font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }};
              font-style: {{ block.settings.font.style }};
            }
          </style>
        {% endif %}
      {% when 'team' %}
        {% if block.settings.custom_font %}
          <style>
            #shopify-section-{{ section.id }} .vso-faq-02__team-paragraph {
              font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }};
              font-style: {{ block.settings.font.style }};
            }
          </style>
        {% endif %}
    {% endcase %}
  {% endfor %}
  
{%- if request.design_mode -%}
  <div class="vso-require-script">
    <div class="vso-warning">
      <div class="vso-warning__left">
        <div class="vso-warning__badge">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none">
            <path d="M10 6.75a.75.75 0 0 1 .75.75v3.5a.75.75 0 1 1-1.5 0v-3.5a.75.75 0 0 1 .75-.75Z" fill="currentColor"/>
            <path d="M11 13.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z" fill="currentColor"/>
            <path fill-rule="evenodd" d="M10 3.5c-1.045 0-1.784.702-2.152 1.447a449.26 449.26 0 0 1-2.005 3.847l-.028.052a403.426 403.426 0 0 0-2.008 3.856c-.372.752-.478 1.75.093 2.614.57.863 1.542 1.184 2.464 1.184h7.272c.922 0 1.895-.32 2.464-1.184.57-.864.465-1.862.093-2.614-.21-.424-1.113-2.147-2.004-3.847l-.032-.061a429.497 429.497 0 0 1-2.005-3.847c-.368-.745-1.107-1.447-2.152-1.447Zm-.808 2.112c.404-.816 1.212-.816 1.616 0 .202.409 1.112 2.145 2.022 3.88a418.904 418.904 0 0 1 2.018 3.875c.404.817 0 1.633-1.212 1.633h-7.272c-1.212 0-1.617-.816-1.212-1.633.202-.408 1.113-2.147 2.023-3.883a421.932 421.932 0 0 0 2.017-3.872Z" fill="currentColor"/>
          </svg>
          <span>Action Required</span>
        </div>
        <h2 class="vso-warning__title">App Embeds Are Disabled</h2>
        <p class="vso-warning__subtitle">Enable the Versio Sections app embed in your theme editor to use this section.</p>
        <div class="vso-warning__steps">
          <div class="vso-warning__step">
            <span class="vso-warning__step-number">1</span>
            <span>Click the <strong>App embeds</strong> icon (puzzle piece) at the top of the left sidebar</span>
          </div>
          <div class="vso-warning__step">
            <span class="vso-warning__step-number">2</span>
            <span>Toggle on <strong>Versio Sections</strong></span>
          </div>
          <div class="vso-warning__step">
            <span class="vso-warning__step-number">3</span>
            <span>Click <strong>Save</strong> in the top right</span>
          </div>
        </div>
      </div>
      <div class="vso-warning__image">
        <img src="https://cdn.shopify.com/s/files/1/0970/2880/0861/files/1.png?v=1773296966" alt="How to enable app embeds" loading="lazy" width="640" height="880" />
      </div>
    </div>
  </div>
  <style>
    .vso-hidden {
      display: none !important;
      height: 0 !important;
      overflow: hidden !important;
      visibility: hidden !important;
      width: 0 !important;
      opacity: 0 !important;
