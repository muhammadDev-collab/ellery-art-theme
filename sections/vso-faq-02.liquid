  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const sectionId = '{{ section.id }}';
      const accordionItems = document.querySelectorAll(`.vso-faq-02-section-${sectionId} .vso-faq-02__faq-item`);
      const icons = {
        open: '<path d="M5 12H19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
        closed: '<path d="M12 5V19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 12H19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>'
      };
      function closeAll(except) {
        accordionItems.forEach(item => {
          if (except && item === except) return;
          const answer = item.querySelector('.vso-faq-02__faq-answer');
          const toggle = item.querySelector('.vso-faq-02__faq-toggle svg');
          item.classList.remove('active');
          item.querySelector('.vso-faq-02__faq-question').setAttribute('aria-expanded', 'false');
          answer.style.height = '0px';
          if (toggle) toggle.innerHTML = icons.closed;
        });
      }
      function toggle(item) {
        const active = item.classList.contains('active');
        const answer = item.querySelector('.vso-faq-02__faq-answer');
        const toggle = item.querySelector('.vso-faq-02__faq-toggle svg');
        if (active) {
          item.classList.remove('active');
          item.querySelector('.vso-faq-02__faq-question').setAttribute('aria-expanded', 'false');
          answer.style.height = '0px';
          if (toggle) toggle.innerHTML = icons.closed;
        } else {
          closeAll(item);
          item.classList.add('active');
          item.querySelector('.vso-faq-02__faq-question').setAttribute('aria-expanded', 'true');
          answer.style.height = answer.scrollHeight + 'px';
          if (toggle) toggle.innerHTML = icons.open;
        }
      }
      accordionItems.forEach(item => {
        const question = item.querySelector('.vso-faq-02__faq-question');
        question.addEventListener('click', () => toggle(item));
        question.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(item); }
        });
      });
    });
  </script>
  
