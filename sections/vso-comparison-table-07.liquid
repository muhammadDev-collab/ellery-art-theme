{%- liquid
  assign heading_block = section.blocks | where: 'type', 'heading' | first
  assign description_block = section.blocks | where: 'type', 'description' | first
  assign button_block = section.blocks | where: 'type', 'button' | first

  assign heading_color = '#ffffff'
  assign heading_custom_font = false
  assign heading_font = blank
  assign heading_font_size_desktop = 48
  assign heading_font_size_mobile = 32
  assign heading_font_weight = 700
  assign heading_line_height = 120
  assign heading_max_width_desktop = 600
  assign heading_alignment_desktop = 'center'
  assign heading_alignment_mobile = 'center'
  assign heading_margin_top = 0
  assign heading_margin_bottom = 16
  assign heading_margin_top_mobile = 0
  assign heading_margin_bottom_mobile = 16
  assign heading_horizontal_padding_desktop = 0
  assign heading_horizontal_padding_mobile = 0

  if heading_block != blank
    assign heading_color = heading_block.settings.heading_color | default: '#ffffff'
    assign heading_custom_font = heading_block.settings.heading_custom_font | default: false
    assign heading_font = heading_block.settings.heading_font
    assign heading_font_size_desktop = heading_block.settings.heading_font_size_desktop | default: 48
    assign heading_font_size_mobile = heading_block.settings.heading_font_size_mobile | default: 32
    assign heading_font_weight = heading_block.settings.heading_font_weight | default: 700
    assign heading_line_height = heading_block.settings.heading_line_height | default: 120
    assign heading_max_width_desktop = heading_block.settings.heading_max_width_desktop | default: 600
    assign heading_alignment_desktop = heading_block.settings.heading_alignment_desktop | default: 'center'
    assign heading_alignment_mobile = heading_block.settings.heading_alignment_mobile | default: 'center'
    assign heading_margin_top = heading_block.settings.heading_margin_top | default: 0
    assign heading_margin_bottom = heading_block.settings.heading_margin_bottom | default: 16
    assign heading_margin_top_mobile = heading_block.settings.heading_margin_top_mobile | default: 0
    assign heading_margin_bottom_mobile = heading_block.settings.heading_margin_bottom_mobile | default: 16
    assign heading_horizontal_padding_desktop = heading_block.settings.heading_horizontal_padding_desktop | default: 0
    assign heading_horizontal_padding_mobile = heading_block.settings.heading_horizontal_padding_mobile | default: 0
  endif

  assign description_color = '#e5e7eb'
  assign description_custom_font = false
  assign description_font = blank
  assign description_font_size_desktop = 18
  assign description_font_size_mobile = 16
  assign description_font_weight = 400
  assign description_max_width_desktop = 600
  assign description_alignment_desktop = 'center'
  assign description_alignment_mobile = 'center'
  assign description_margin_top = 0
  assign description_margin_bottom = 0
  assign description_margin_top_mobile = 0
  assign description_margin_bottom_mobile = 0
  assign description_horizontal_padding_desktop = 0
  assign description_horizontal_padding_mobile = 0

  if description_block != blank
    assign description_color = description_block.settings.description_color | default: '#e5e7eb'
    assign description_custom_font = description_block.settings.description_custom_font | default: false
    assign description_font = description_block.settings.description_font
    assign description_font_size_desktop = description_block.settings.description_font_size_desktop | default: 18
    assign description_font_size_mobile = description_block.settings.description_font_size_mobile | default: 16
    assign description_font_weight = description_block.settings.description_font_weight | default: 400
    assign description_max_width_desktop = description_block.settings.description_max_width_desktop | default: 600
    assign description_alignment_desktop = description_block.settings.description_alignment_desktop | default: 'center'
    assign description_alignment_mobile = description_block.settings.description_alignment_mobile | default: 'center'
    assign description_margin_top = description_block.settings.description_margin_top | default: 0
    assign description_margin_bottom = description_block.settings.description_margin_bottom | default: 0
    assign description_margin_top_mobile = description_block.settings.description_margin_top_mobile | default: 0
    assign description_margin_bottom_mobile = description_block.settings.description_margin_bottom_mobile | default: 0
    assign description_horizontal_padding_desktop = description_block.settings.description_horizontal_padding_desktop | default: 0
    assign description_horizontal_padding_mobile = description_block.settings.description_horizontal_padding_mobile | default: 0
  endif

  assign button_custom_font = false
  assign button_font = blank
  assign button_font_size_desktop = 14
  assign button_font_size_mobile = 14
  assign button_font_weight = 600
  assign button_line_height = 120
  assign button_bg_color = '#C8AA6E'
  assign button_hover_bg_color = '#b8993e'
  assign button_text_color = '#1a1a1a'
  assign button_hover_text_color = '#1a1a1a'
  assign button_horizontal_padding = 28
  assign button_horizontal_padding_mobile = 24
  assign button_vertical_padding = 14
  assign button_border_radius = 999
  assign button_alignment_desktop = 'center'
  assign button_alignment_mobile = 'center'
  assign button_margin_top = 20
  assign button_margin_bottom = 0
  assign button_margin_top_mobile = 18
  assign button_margin_bottom_mobile = 0

  if button_block != blank
    assign button_custom_font = button_block.settings.button_custom_font | default: false
    assign button_font = button_block.settings.button_font
    assign button_font_size_desktop = button_block.settings.button_font_size_desktop | default: 14
    assign button_font_size_mobile = button_block.settings.button_font_size_mobile | default: 14
    assign button_font_weight = button_block.settings.button_font_weight | default: 600
    assign button_line_height = button_block.settings.button_line_height | default: 120
    assign button_bg_color = button_block.settings.button_bg_color | default: '#C8AA6E'
    assign button_hover_bg_color = button_block.settings.button_hover_bg_color | default: '#b8993e'
    assign button_text_color = button_block.settings.button_text_color | default: '#1a1a1a'
    assign button_hover_text_color = button_block.settings.button_hover_text_color | default: '#1a1a1a'
    assign button_horizontal_padding = button_block.settings.button_horizontal_padding | default: 28
    assign button_horizontal_padding_mobile = button_block.settings.button_horizontal_padding_mobile | default: 24
    assign button_vertical_padding = button_block.settings.button_vertical_padding | default: 14
    assign button_border_radius = button_block.settings.button_border_radius | default: 999
    assign button_alignment_desktop = button_block.settings.button_alignment_desktop | default: 'center'
    assign button_alignment_mobile = button_block.settings.button_alignment_mobile | default: 'center'
    assign button_margin_top = button_block.settings.button_margin_top | default: 20
    assign button_margin_bottom = button_block.settings.button_margin_bottom | default: 0
    assign button_margin_top_mobile = button_block.settings.button_margin_top_mobile | default: 18
    assign button_margin_bottom_mobile = button_block.settings.button_margin_bottom_mobile | default: 0
  endif

  assign section_bg_value = section.settings.section_bg_color
  if section.settings.background_type == 'gradient'
    assign section_bg_value = section.settings.section_bg_gradient
  endif
-%}

{%- style -%}
  .vd-l { display: none !important; }
  #shopify-section-{{ section.id }} {
    --section-border-radius: 0px;
    --section-horizontal-padding: var(--page-margin, 16px);
    --table-border-style: {{ section.settings.table_border_style }};
    background: transparent;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    border-radius: var(--section-border-radius);
    overflow: hidden;
    padding: 0;
  }

  {% if section.settings.enable_advanced_settings %}
    #shopify-section-{{ section.id }} {
      --section-horizontal-padding: {{ section.settings.padding_horizontal_mobile }}px;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      background: {{ section_bg_value }};
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      {% if section.settings.bg_full_width_desktop %}
        --section-border-radius: 0px;
      {% else %}
        --section-border-radius: {{ section.settings.section_border_radius }}px;
      {% endif %}
      --section-horizontal-padding: 0px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
      {% if section.settings.bg_full_width_desktop %}
        background: {{ section_bg_value }};
      {% else %}
        background: transparent;
      {% endif %}
    }
  }

  {% if section.settings.enable_advanced_settings == false and section.settings.bg_full_width_desktop == false %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        --section-horizontal-padding: 40px;
      }
    }
  {% endif %}

  {% if section.settings.enable_advanced_settings == false and section.settings.bg_full_width_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        --section-container-max-width: var(--page-content-width, var(--page-width, 1440px));
        --section-outer-gutter: max(0px, calc((100vw - var(--section-container-max-width)) / 2));
        --section-horizontal-padding: max(0px, calc(var(--page-margin, 40px) - var(--section-outer-gutter)));
      }
    }
  {% endif %}

  {% if section.settings.enable_advanced_settings %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        --section-horizontal-padding: {{ section.settings.padding_horizontal }}px;
      }
    }
  {% endif %}

  #shopify-section-{{ section.id }} > .vso-comparison-table-04__container {
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    max-width: var(--page-content-width, var(--page-width, 1440px));
    {% if section.settings.enable_advanced_settings %}
      max-width: {{ section.settings.section_max_width }}rem;
    {% endif %}
    border-radius: var(--section-border-radius);
    overflow: hidden;
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: var(--section-horizontal-padding);
    padding-right: var(--section-horizontal-padding);
  }

  {% if section.settings.bg_full_width_desktop == false %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} > .vso-comparison-table-04__container {
        width: calc(100% - (2 * var(--page-margin, 40px)));
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} > .vso-comparison-table-04__container {
      background: transparent;
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} > .vso-comparison-table-04__container {
      {% if section.settings.bg_full_width_desktop %}
        background: transparent;
      {% else %}
        background: {{ section_bg_value }};
      {% endif %}
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__inner {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__content {
    display: flex;
    flex-direction: column;
    padding: 0;
  }
  
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-comparison-table-04__content {
      padding: 0;
    }
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__heading {
    margin-top: {{ heading_margin_top_mobile }}px;
    margin-bottom: {{ heading_margin_bottom_mobile }}px;
    padding-left: {{ heading_horizontal_padding_mobile }}px;
    padding-right: {{ heading_horizontal_padding_mobile }}px;
    text-align: {{ heading_alignment_mobile }};
    color: {{ heading_color }};
    line-height: {{ heading_line_height }}%;
  }

  {%- if heading_custom_font -%}
    #shopify-section-{{ section.id }} .vso-comparison-table-04__heading {
      font-size: {{ heading_font_size_mobile }}px;
      font-weight: {{ heading_font_weight }};
      font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
      font-style: {{ heading_font.style }};
    }

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .vso-comparison-table-04__heading {
        font-size: {{ heading_font_size_desktop }}px;
      }
    }
  {%- endif -%}

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-comparison-table-04__heading {
      margin-top: {{ heading_margin_top }}px;
      margin-bottom: {{ heading_margin_bottom }}px;
      padding-left: {{ heading_horizontal_padding_desktop }}px;
      padding-right: {{ heading_horizontal_padding_desktop }}px;
      text-align: {{ heading_alignment_desktop }};
      max-width: {{ heading_max_width_desktop }}px;
      {% if heading_alignment_desktop == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% endif %}
    }
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__description {
    margin-top: {{ description_margin_top_mobile }}px;
    margin-bottom: {{ description_margin_bottom_mobile }}px;
    padding-left: {{ description_horizontal_padding_mobile }}px;
    padding-right: {{ description_horizontal_padding_mobile }}px;
    text-align: {{ description_alignment_mobile }};
    color: {{ description_color }};
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__description > *,
  #shopify-section-{{ section.id }} .vso-comparison-table-04__description + p {
    color: {{ description_color }} !important;
    margin-top: 0 !important;
  }

  {%- if description_custom_font -%}
    #shopify-section-{{ section.id }} .vso-comparison-table-04__description {
      font-size: {{ description_font_size_mobile }}px;
      font-weight: {{ description_font_weight }};
      font-family: {{ description_font.family }}, {{ description_font.fallback_families }};
      font-style: {{ description_font.style }};
    }

    #shopify-section-{{ section.id }} .vso-comparison-table-04__description > * {
      font-size: {{ description_font_size_mobile }}px;
      font-weight: {{ description_font_weight }};
    }

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .vso-comparison-table-04__description {
        font-size: {{ description_font_size_desktop }}px;
      }

      #shopify-section-{{ section.id }} .vso-comparison-table-04__description > * {
        font-size: {{ description_font_size_desktop }}px;
      }
    }
  {%- endif -%}

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-comparison-table-04__description {
      margin-top: {{ description_margin_top }}px;
      margin-bottom: {{ description_margin_bottom }}px;
      padding-left: {{ description_horizontal_padding_desktop }}px;
      padding-right: {{ description_horizontal_padding_desktop }}px;
      text-align: {{ description_alignment_desktop }};
      max-width: {{ description_max_width_desktop }}px;
      {% if description_alignment_desktop == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% endif %}
    }
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__button-container {
    margin-top: {{ button_margin_top_mobile }}px;
    margin-bottom: {{ button_margin_bottom_mobile }}px;
    text-align: {{ button_alignment_mobile }};
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-comparison-table-04__button-container {
      margin-top: {{ button_margin_top }}px;
      margin-bottom: {{ button_margin_bottom }}px;
      text-align: {{ button_alignment_desktop }};
    }
  }
  #shopify-section-{{ section.id }} .vso-comparison-table-04__button {
    padding: {{ button_vertical_padding }}px {{ button_horizontal_padding_mobile }}px;
    border-radius: {{ button_border_radius }}px;
    background: {{ button_bg_color }};
    color: {{ button_text_color }};
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease;
    line-height: {{ button_line_height }}%;
  }

  {%- if button_custom_font -%}
    #shopify-section-{{ section.id }} .vso-comparison-table-04__button {
      font-size: {{ button_font_size_mobile }}px;
      font-weight: {{ button_font_weight }};
      font-family: {{ button_font.family }}, {{ button_font.fallback_families }};
      font-style: {{ button_font.style }};
    }

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .vso-comparison-table-04__button {
        font-size: {{ button_font_size_desktop }}px;
      }
    }
  {%- endif -%}

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-comparison-table-04__button {
      padding: {{ button_vertical_padding }}px {{ button_horizontal_padding }}px;
    }
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__button:hover {
    background: {{ button_hover_bg_color }};
    color: {{ button_hover_text_color }};
  }

  #shopify-section-{{ section.id }} .vso-comparison-table-04__table {
    padding: {{ section.settings.table_padding }}px;
    border-radius: {{ section.settings.table_border_radius }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-comparison-table-04__table {
      {% if section.settings.enable_table_max_width_desktop %}
        max-width: {{ section.settings.table_max_width_desktop }}px;
      {% endif %}
      margin-left: auto;
      margin-right: auto;
    }
  }

  #shopify-section-{{ section.id }} .comparison-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: {{ section.settings.table_border_radius }}px;
    overflow: hidden;
    table-layout: fixed;
    position: relative;
  }

  {% if section.settings.active_background_type == 'gradient' %}
    {% if section.settings.active_column == '1' %}
      #shopify-section-{{ section.id }} .comparison-table::before {
        content: '';
        position: absolute;
        top: 0;
        left: 33.33%;
        width: 33.33%;
        height: 100%;
        background: {{ section.settings.active_bg_gradient }};
        pointer-events: none;
        border-radius: {{ section.settings.table_border_radius }}px;
        z-index: 0;
      }
    {% elsif section.settings.active_column == '2' %}
      #shopify-section-{{ section.id }} .comparison-table::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 33.33%;
        height: 100%;
        background: {{ section.settings.active_bg_gradient }};
        pointer-events: none;
        border-radius: {{ section.settings.table_border_radius }}px;
        z-index: 0;
      }
    {% endif %}
  {% endif %}

  #shopify-section-{{ section.id }} .comparison-table th {
    background-color: transparent;
    color: {{ section.settings.header_text_color }};
    font-weight: {{ section.settings.header_font_weight }};
    font-size: {{ section.settings.header_font_size_mobile }}px;
    line-height: {{ section.settings.header_line_height }}%;
    padding: {{ section.settings.header_padding }}px;
    text-align: center;
    border: none;
  }

  {% if section.settings.table_custom_font %}
    #shopify-section-{{ section.id }} .comparison-table th,
    #shopify-section-{{ section.id }} .comparison-table td {
      font-family: {{ section.settings.table_font.family }}, {{ section.settings.table_font.fallback_families }};
      font-style: {{ section.settings.table_font.style }};
    }
  {% endif %}

  #shopify-section-{{ section.id }} .comparison-table thead tr > th {
    border: none;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .comparison-table th {
      font-size: {{ section.settings.header_font_size_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .comparison-table th {
      padding: {{ section.settings.header_padding_mobile }}px;
    }
  }

  #shopify-section-{{ section.id }} .comparison-table th.active-column {
    background: {% if section.settings.active_background_type == 'gradient' %}transparent{% else %}{{ section.settings.active_bg_color }}{% endif %};
    color: {{ section.settings.active_text_color }};
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .comparison-table thead th.active-column {
    border-bottom: none;
  }

  #shopify-section-{{ section.id }} .comparison-table th.feature-header {
    background: transparent;
    border: none;
    padding: 0;
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .comparison-table thead tr > th:nth-child(2).active-column {
    border-top-left-radius: {{ section.settings.table_border_radius }}px;
    border-top-right-radius: {{ section.settings.table_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .comparison-table tbody tr:last-child td:nth-child(2).active-column {
    border-bottom-left-radius: {{ section.settings.table_border_radius }}px;
    border-bottom-right-radius: {{ section.settings.table_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .comparison-table thead tr > th:nth-child(3).active-column {
    border-top-left-radius: {{ section.settings.table_border_radius }}px;
    border-top-right-radius: {{ section.settings.table_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .comparison-table tbody tr:last-child td:nth-child(3).active-column {
    border-bottom-left-radius: {{ section.settings.table_border_radius }}px;
    border-bottom-right-radius: {{ section.settings.table_border_radius }}px;
  }


  #shopify-section-{{ section.id }} .comparison-table td {
    padding: {{ section.settings.cell_padding }}px;
    text-align: center;
    vertical-align: middle;
    border-left: none;
    border-right: none;
    border-top: none;
    border-bottom: {{ section.settings.table_border_width }}px var(--table-border-style) {{ section.settings.table_border_color }};
    font-size: {{ section.settings.cell_font_size_mobile }}px;
    color: {{ section.settings.table_text_color }};
    background-color: transparent;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .comparison-table td {
      font-size: {{ section.settings.cell_font_size_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .comparison-table td {
      padding: {{ section.settings.cell_padding_mobile }}px;
    }
  }

  #shopify-section-{{ section.id }} .comparison-table tbody tr > td:first-child {
    border-left: none;
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .comparison-table tbody tr > td:last-child {
    border-right: none;
  }

  #shopify-section-{{ section.id }} .comparison-table .feature-label {
    text-align: left;
    font-weight: {{ section.settings.feature_label_font_weight }};
    background-color: transparent;
    padding-left: 0;
  }

  #shopify-section-{{ section.id }} .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  #shopify-section-{{ section.id }} .comparison-table td.active-column {
    background: {% if section.settings.active_background_type == 'gradient' %}transparent{% else %}{{ section.settings.active_bg_color }}{% endif %};
    color: {{ section.settings.active_text_color }};
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .icon-check,
  #shopify-section-{{ section.id }} .icon-cross {
    width: {{ section.settings.icon_size_mobile }}px;
    height: {{ section.settings.icon_size_mobile }}px;
    display: block;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .icon-check,
    #shopify-section-{{ section.id }} .icon-cross {
      width: {{ section.settings.icon_size }}px;
      height: {{ section.settings.icon_size }}px;
    }
  }

  .vso-node { display: none; }
  .vso-node--v2 { display: block; }
{%- endstyle -%}

{%- if request.design_mode -%}
  <div class="vso-require-script">
    <div class="vso-warning">
      <div class="vso-warning__left">
