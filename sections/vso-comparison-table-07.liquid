<div class="vso-comparison-table-04__container vso-node vso-hidden">
    <div class="vso-comparison-table-04__inner">
      <div class="vso-comparison-table-04__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- if block.settings.heading != blank -%}
                {%- assign heading_tag = block.settings.heading_as | default: 'h2' -%}
                <{{ heading_tag }} class="vso-comparison-table-04__heading" {{ block.shopify_attributes }}>{{ block.settings.heading }}</{{ heading_tag }}>
              {%- endif -%}
            {%- when 'description' -%}
              {%- if block.settings.description != blank -%}
                {%- assign description_tag = block.settings.description_as | default: 'p' -%}
                <{{ description_tag }} class="vso-comparison-table-04__description" {{ block.shopify_attributes }}>{{ block.settings.description }}</{{ description_tag }}>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}

      </div>

      <div class="vso-comparison-table-04__table">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="feature-header"></th>
              <th {% if section.settings.active_column == '1' %}class="active-column"{% endif %}>
                {% if section.settings.column_1_image != blank %}
                  <img src="{{ section.settings.column_1_image | image_url: width: 120 }}" alt="{{ section.settings.column_1_image.alt | escape }}" width="120" height="{{ 120 | divided_by: section.settings.column_1_image.aspect_ratio | round }}" style="max-width: 100%; height: auto;">
                {% else %}
                  {{ section.settings.column_1_header }}
                {% endif %}
              </th>
              <th {% if section.settings.active_column == '2' %}class="active-column"{% endif %}>
                {% if section.settings.column_2_image != blank %}
                  <img src="{{ section.settings.column_2_image | image_url: width: 120 }}" alt="{{ section.settings.column_2_image.alt | escape }}" width="120" height="{{ 120 | divided_by: section.settings.column_2_image.aspect_ratio | round }}" style="max-width: 100%; height: auto;">
                {% else %}
                  {{ section.settings.column_2_header }}
                {% endif %}
              </th>
            </tr>
          </thead>
          <tbody>
            {%- for block in section.blocks -%}
              {%- if block.type == 'table_row' -%}
                <tr {{ block.shopify_attributes }}>
                  <td class="feature-label">{{ block.settings.feature_name }}</td>
                  <td {% if section.settings.active_column == '1' %}class="active-column"{% endif %}>
                    {% if block.settings.column_1_custom_image != blank %}
                      <img src="{{ block.settings.column_1_custom_image | image_url: width: 32 }}" alt="{{ block.settings.column_1_custom_image.alt | escape }}" width="{{ section.settings.icon_size_mobile }}" height="{{ section.settings.icon_size_mobile }}">
                    {% elsif block.settings.column_1_value != blank %}
                      {{ block.settings.column_1_value }}
                    {% else %}
                      {% case block.settings.column_1_icon %}
                        {% when 'check' %}
                          <svg class="icon-check" viewBox="-2.4 -2.4 28.80 28.80">
                            <rect x="-2.4" y="-2.4" width="28.80" height="28.80" rx="14.4" fill="{{ section.settings.check_circle_bg_color }}"/>
                            <path d="M6 12L10.2426 16.2426L18.727 7.75732" stroke="{{ section.settings.check_icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                          </svg>
                        {% when 'cross' %}
                          <svg class="icon-cross" viewBox="0 0 32 32">
                            <circle cx="16" cy="16" r="16" fill="{{ section.settings.cross_circle_bg_color }}"/>
                            <path d="M21.657,20.24 C22.048,20.63 22.048,21.27 21.657,21.66 C21.267,22.05 20.633,22.05 20.242,21.66 L16.006,17.42 L11.74,21.69 C11.346,22.08 10.708,22.08 10.314,21.69 C9.921,21.29 9.921,20.65 10.314,20.26 L14.58,15.99 L10.344,11.76 C9.953,11.37 9.953,10.73 10.344,10.34 C10.733,9.95 11.367,9.95 11.758,10.34 L15.994,14.58 L20.292,10.28 C20.686,9.89 21.323,9.89 21.717,10.28 C22.11,10.68 22.11,11.31 21.717,11.71 L17.42,16.01 L21.657,20.24 L21.657,20.24 Z" fill="{{ section.settings.cross_icon_color }}"/>
                          </svg>
                      {% endcase %}
                    {% endif %}
                  </td>
                  <td {% if section.settings.active_column == '2' %}class="active-column"{% endif %}>
                    {% if block.settings.column_2_custom_image != blank %}
                      <img src="{{ block.settings.column_2_custom_image | image_url: width: 32 }}" alt="{{ block.settings.column_2_custom_image.alt | escape }}" width="{{ section.settings.icon_size_mobile }}" height="{{ section.settings.icon_size_mobile }}">
                    {% elsif block.settings.column_2_value != blank %}
                      {{ block.settings.column_2_value }}
                    {% else %}
                      {% case block.settings.column_2_icon %}
                        {% when 'check' %}
                          <svg class="icon-check" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="30" height="30" rx="15" fill="{{ section.settings.check_circle_bg_color }}" />
                            <path d="m21.6667 10.5-9.1667 9.1667L8 15.1667" stroke="{{ section.settings.check_icon_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        {% when 'none' %}
                        {% when 'cross' %}
                          <svg class="icon-cross" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="30" height="30" rx="15" fill="{{ section.settings.cross_circle_bg_color }}" />
                            <path d="M19 11L11 19M11 11l8 8" stroke="{{ section.settings.cross_icon_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                      {% endcase %}
                    {% endif %}
                  </td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'button' and block.settings.button_label != blank -%}
          <div class="vso-comparison-table-04__button-container" {{ block.shopify_attributes }}>
            {%- assign btn_url = block.settings.button_url -%}
            {%- if block.settings.button_link_type == 'scroll_to_buy_buttons' -%}
              <a href="#" class="vso-comparison-table-04__button" data-vso-scroll-to-buy-buttons="true">{{ block.settings.button_label }}</a>
            {%- elsif btn_url != blank -%}
              <a href="{{ btn_url }}" class="vso-comparison-table-04__button">{{ block.settings.button_label }}</a>
            {%- else -%}
              <button class="vso-comparison-table-04__button" type="button">{{ block.settings.button_label }}</button>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
</div>

<script>
  (() => {
    const sectionEl = document.getElementById('shopify-section-{{ section.id }}');
    if (!sectionEl) return;

    const links = sectionEl.querySelectorAll('[data-vso-scroll-to-buy-buttons="true"]');
    if (!links.length) return;

    const isEligibleTarget = (el) => {
      if (!el) return false;
      if (el.closest('[hidden], [aria-hidden="true"]')) return false;
      if (el.closest('product-card, .product-card, quick-add-component, quick-add-dialog, .quick-add, .quick-add-modal, .card-wrapper')) {
        return false;
      }

      const rect = el.getBoundingClientRect();
      if (rect.width <= 0 || rect.height <= 0) return false;

      const style = window.getComputedStyle(el);
      if (style.display == 'none' || style.visibility == 'hidden') return false;

      return true;
    };

    const pickFirstVisibleByTop = (selectors) => {
      const positioned = selectors
        .flatMap((selector) => Array.from(document.querySelectorAll(selector)))
        .filter(isEligibleTarget)
        .map((el) => ({ el, top: el.getBoundingClientRect().top + window.scrollY }));

      if (!positioned.length) return null;
      positioned.sort((a, b) => a.top - b.top);
      return positioned[0].el;
    };

    const findTarget = () => {
      const primarySelectors = [
        '.product-form__buttons',
        '.product-form-buttons',
        '.ProductForm__BuyButtons',
        '.buy-buttons-block'
      ];
      const fallbackSelectors = [
        '.shopify-payment-button',
        '[data-product-form]',
        'product-form form',
        'form[action$="/cart/add"]',
        'form[action*="/cart/add"]',
        'form.product-form'
      ];

      return pickFirstVisibleByTop(primarySelectors) || pickFirstVisibleByTop(fallbackSelectors);
    };

    const scrollNearViewportBottom = (target) => {
      const rect = target.getBoundingClientRect();
      const targetTop = rect.top + window.scrollY;
      const bottomOffset = Math.max(24, Math.min(140, Math.round(window.innerHeight * 0.12)));
      const maxTopOffset = Math.max(0, window.innerHeight - rect.height - bottomOffset);
      const scrollTop = Math.max(0, targetTop - maxTopOffset);
      window.scrollTo({ top: scrollTop, behavior: 'smooth' });
    };

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        const target = findTarget();
        if (!target) return;
        scrollNearViewportBottom(target);
      });
    });
  })();
</script>

