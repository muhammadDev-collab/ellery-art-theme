{%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

<style>
  #shopify-section-{{ section.id }} .ss-social-proof {
    text-align: center;
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__heading {
    font-family: 'DIN Next LT Pro Cond', Arial Narrow, sans-serif !important;
    font-size: 24px !important;
    font-weight: 500 !important;
    text-transform: uppercase !important;
    margin-bottom: 14px;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__trustpilot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: 40px;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__stars {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__star {
    width: 18px;
    height: 18px;
    background-color: #00b67a;
    display: flex;
    display: flex;
    align-items: center;
    justify-content: center;
    align-content: center;

  }

  #shopify-section-{{ section.id }} .ss-social-proof__star svg {
    width: 11px;
    height: 11px;
    fill: #ffffff;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__review-count {
    font-family: 'Adobe Caslon Pro' !important;
    font-style: italic;
    color: #626262;
    font-size: 16px !important;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__review-count a {
    color: inherit;
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__press-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 32px 24px;
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} .ss-social-proof__press-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  #shopify-section-{{ section.id }} .ss-social-proof__press-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__press-quote {
    font-size: 0.9375rem;
    font-style: italic;
    line-height: 1.5;
    color: inherit;
    opacity: 0.75;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__press-logo img {
    max-height: {{ section.settings.logo_max_height }}px;
    width: auto;
    display: block;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .ss-social-proof__press-logo-text {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: inherit;
  }
</style>

<div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }} {% if section.settings.separate_section_with_border %}bordered-section{% endif %}">
  <div class="container container--xl">
    <div class="ss-social-proof">

      {%- comment %} — Heading — {% endcomment %}
      {%- if section.settings.heading != blank -%}
        <h2 class="ss-social-proof__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- comment %} — Trustpilot Stars + Review Count — {% endcomment %}
      <div class="ss-social-proof__trustpilot">
        <div class="ss-social-proof__stars">
          {%- for i in (1..5) -%}
            <div class="ss-social-proof__star">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 2l2.9 8.9H23l-7.4 5.4 2.8 8.7L12 19.6l-6.4 5.4 2.8-8.7L1 10.9h8.1z"/>
              </svg>
            </div>
          {%- endfor -%}
        </div>
        <p class="ss-social-proof__review-count">
          {{ section.settings.review_text }}
          {%- if section.settings.review_link != blank -%}
            <a href="{{ section.settings.review_link }}">{{ section.settings.review_link_text }}</a>
          {%- else -%}
            {{ section.settings.review_link_text }}
          {%- endif -%}
        </p>
      </div>

      {%- comment %} — Press / Media Grid — {% endcomment %}
      {%- if section.blocks.size > 0 -%}
        <div class="ss-social-proof__press-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'press_item' -%}
              <div class="ss-social-proof__press-item" {{ block.shopify_attributes }}>
                {%- if block.settings.quote != blank -%}
                  <p class="ss-social-proof__press-quote">"{{ block.settings.quote }}"</p>
                {%- endif -%}
                <div class="ss-social-proof__press-logo">
                  {%- if block.settings.logo != blank -%}
                    {{- block.settings.logo | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.publication_name -}}
                  {%- elsif block.settings.publication_name != blank -%}
                    <span class="ss-social-proof__press-logo-text">{{ block.settings.publication_name }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Social Proof",
  "class": "shopify-section--ss-social-proof",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "Separate section with border",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "+200,000 CUSTOMERS FOR A REASON"
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "text",
      "id": "review_text",
      "label": "Review text (before link)",
      "default": "Based on 10810 "
    },
    {
      "type": "text",
      "id": "review_link_text",
      "label": "Review link label",
      "default": "reviews"
    },
    {
      "type": "url",
      "id": "review_link",
      "label": "Review link URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Logo max height",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "press_item",
      "name": "Press Item",
      "settings": [
        {
          "type": "text",
          "id": "quote",
          "label": "Quote",
          "default": "Some of the best art in the world. Plain and simple."
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Publication logo",
          "info": "Upload the publication logo. If no logo is provided, the text name will be displayed."
        },
        {
          "type": "text",
          "id": "publication_name",
          "label": "Publication name (fallback text)",
          "default": "BuzzFeed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof",
      "category": "Social proof",
      "blocks": [
        {
          "type": "press_item",
          "settings": {
            "quote": "The art and the purpose behind it really makes people talk",
            "publication_name": "BuzzFeed"
          }
        },
        {
          "type": "press_item",
          "settings": {
            "quote": "Some of the best art in the world. Plain and simple.",
            "publication_name": "Variety"
          }
        },
        {
          "type": "press_item",
          "settings": {
            "quote": "Art so good that you will actually wanna have friends over",
            "publication_name": "Wired"
          }
        }
      ]
    }
  ]
}
{% endschema %}
