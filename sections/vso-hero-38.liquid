<div class="vso-hero-38__container vso-node vso-hidden">
  <div class="vso-hero-38__content">

      <div class="vso-hero-38__middle-section">

        <div class="vso-hero-38__left-column">
          {%- for block in section.blocks -%}
            {%- if block.type == 'heading' -%}
              <div class="vso-hero-38__heading-block" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                {% if block.settings.subheading != blank %}
                  {%- if block.settings.subheading_custom_font -%}
                    <div class="vso-hero-38__subheading">{{ block.settings.subheading }}</div>
                  {%- else -%}
                    {%- assign subheading_tag = block.settings.subheading_as | default: 'p' -%}
                    <{{ subheading_tag }} class="vso-hero-38__subheading">{{ block.settings.subheading }}</{{ subheading_tag }}>
                  {%- endif -%}
                {% endif %}

                {% if block.settings.heading != blank %}
                  {%- if block.settings.heading_custom_font -%}
                    <div class="vso-hero-38__heading">{{ block.settings.heading }}</div>
                  {%- else -%}
                    {%- assign heading_tag = block.settings.heading_as | default: 'h2' -%}
                    <{{ heading_tag }} class="vso-hero-38__heading">{{ block.settings.heading }}</{{ heading_tag }}>
                  {%- endif -%}
                {% endif %}
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.type == 'paragraph' -%}
              <div class="vso-hero-38__paragraph" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                {% if block.settings.paragraph_text != blank %}
                  {%- if block.settings.paragraph_custom_font -%}
                    <div class="vso-hero-38__paragraph-text">{{ block.settings.paragraph_text }}</div>
                  {%- else -%}
                    {%- assign paragraph_tag = block.settings.paragraph_as | default: 'p' -%}
                    <{{ paragraph_tag }} class="vso-hero-38__paragraph-text">{{ block.settings.paragraph_text }}</{{ paragraph_tag }}>
                  {%- endif -%}
                {% endif %}
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial' -%}
              <div class="vso-hero-38__testimonial" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                {% liquid
                  assign has_desktop_image = false
                  assign has_mobile_image = false
                  if block.settings.image != blank
                    assign has_desktop_image = true
                  endif
                  if block.settings.enable_mobile_image and block.settings.mobile_image != blank
                    assign has_mobile_image = true
                  endif
                %}
                {% if has_desktop_image or has_mobile_image %}
                  <div class="vso-hero-38__testimonial-media">
                    {% liquid
                      assign desktop_image = block.settings.image
                      assign fallback_image = desktop_image
                      if fallback_image == blank and has_mobile_image
                        assign fallback_image = block.settings.mobile_image
                      endif
                    %}
                    <picture>
                      {% if has_mobile_image %}
                        <source media="(max-width: 749px)" srcset="{{ block.settings.mobile_image | image_url: width: 800 }}">
                      {% endif %}
                      <img
                        src="{{ fallback_image | image_url: width: 800 }}"
                        alt="{{ block.settings.author_name | escape }}"
                        class="vso-hero-38__testimonial-image"
                        width="800"
                        height="600"
                        loading="lazy"
                      >
                    </picture>
                  </div>
                {% endif %}

                <div class="vso-hero-38__testimonial-content">
                  {% if block.settings.quote != blank %}
                    {%- if block.settings.quote_custom_font -%}
                      <div class="vso-hero-38__testimonial-quote">{{ block.settings.quote }}</div>
                    {%- else -%}
                      {%- assign quote_tag = block.settings.quote_as | default: 'p' -%}
                      <{{ quote_tag }} class="vso-hero-38__testimonial-quote">{{ block.settings.quote }}</{{ quote_tag }}>
                    {%- endif -%}
                  {% endif %}

                  {% if block.settings.author_name != blank %}
                    {%- if block.settings.author_custom_font -%}
                      <div class="vso-hero-38__testimonial-author">{{ block.settings.author_name }}</div>
                    {%- else -%}
                      {%- assign author_tag = block.settings.author_as | default: 'p' -%}
                      <{{ author_tag }} class="vso-hero-38__testimonial-author">{{ block.settings.author_name }}</{{ author_tag }}>
                    {%- endif -%}
                  {% endif %}

                  {% if block.settings.verified_buyer_text != blank %}
                    <div class="vso-hero-38__verified-badge">
                      <svg class="vso-hero-38__verified-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M21.007 8.27C22.194 9.125 23 10.45 23 12c0 1.55-.806 2.876-1.993 3.73.24 1.442-.134 2.958-1.227 4.05-1.095 1.095-2.61 1.459-4.046 1.225C14.883 22.196 13.546 23 12 23c-1.55 0-2.878-.807-3.731-1.996-1.438.235-2.954-.128-4.05-1.224-1.095-1.095-1.459-2.611-1.217-4.05C1.816 14.877 1 13.551 1 12s.816-2.878 2.002-3.73c-.242-1.439.122-2.955 1.218-4.05 1.093-1.094 2.61-1.467 4.057-1.227C9.125 1.804 10.453 1 12 1c1.545 0 2.88.803 3.732 1.993 1.442-.24 2.956.135 4.048 1.227 1.093 1.092 1.468 2.608 1.227 4.05Zm-4.426-.084a1 1 0 0 1 .233 1.395l-5 7a1 1 0 0 1-1.521.126l-3-3a1 1 0 0 1 1.414-1.414l2.165 2.165 4.314-6.04a1 1 0 0 1 1.395-.232Z"></path>
                      </svg>
                      {%- if block.settings.badge_custom_font -%}
                        <span>{{ block.settings.verified_buyer_text }}</span>
                      {%- else -%}
                        {%- assign badge_tag = block.settings.badge_as | default: 'p' -%}
                        <{{ badge_tag }}>{{ block.settings.verified_buyer_text }}</{{ badge_tag }}>
                      {%- endif -%}
                    </div>
                  {% endif %}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="vso-hero-38__right-column">
          <div class="vso-hero-38__benefits-grid"
               {% if section.settings.enable_counter_animation %}data-animate-counters="true"{% endif %}>
            {%- for block in section.blocks -%}
              {%- if block.type == 'benefit' -%}
                <div class="vso-hero-38__benefit" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                  {% if section.settings.enable_counter_animation and block.settings.counter_target > 0 %}
                    {%- if section.settings.benefit_number_custom_font -%}
                      <div class="vso-hero-38__benefit-number"
                           data-counter-target="{{ block.settings.counter_target }}"
                           data-counter-suffix="{{ block.settings.counter_suffix | escape }}">
                        0{{ block.settings.counter_suffix }}
                      </div>
                    {%- else -%}
                      {%- assign benefit_number_tag = section.settings.benefit_number_as | default: 'p' -%}
                      <{{ benefit_number_tag }} class="vso-hero-38__benefit-number"
                           data-counter-target="{{ block.settings.counter_target }}"
                           data-counter-suffix="{{ block.settings.counter_suffix | escape }}">
                        0{{ block.settings.counter_suffix }}
                      </{{ benefit_number_tag }}>
                    {%- endif -%}
                  {% elsif block.settings.benefit_number != blank %}
                    {%- if section.settings.benefit_number_custom_font -%}
                      <div class="vso-hero-38__benefit-number">{{ block.settings.benefit_number }}</div>
                    {%- else -%}
                      {%- assign benefit_number_tag = section.settings.benefit_number_as | default: 'p' -%}
                      <{{ benefit_number_tag }} class="vso-hero-38__benefit-number">{{ block.settings.benefit_number }}</{{ benefit_number_tag }}>
                    {%- endif -%}
                  {% endif %}

                  {% if block.settings.benefit_text != blank %}
                    {%- if section.settings.benefit_text_custom_font -%}
                      <div class="vso-hero-38__benefit-text">{{ block.settings.benefit_text }}</div>
                    {%- else -%}
                      {%- assign benefit_text_tag = section.settings.benefit_text_as | default: 'p' -%}
                      <{{ benefit_text_tag }} class="vso-hero-38__benefit-text">{{ block.settings.benefit_text }}</{{ benefit_text_tag }}>
                    {%- endif -%}
                  {% endif %}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- for block in section.blocks -%}
            {%- if block.type == 'disclaimer' -%}
              <div class="vso-hero-38__disclaimer" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                {% if block.settings.disclaimer_text != blank %}
                  {%- if block.settings.disclaimer_custom_font -%}
                    <div class="vso-hero-38__disclaimer-text">{{ block.settings.disclaimer_text }}</div>
                  {%- else -%}
                    {%- assign disclaimer_tag = block.settings.disclaimer_as | default: 'p' -%}
                    <{{ disclaimer_tag }} class="vso-hero-38__disclaimer-text">{{ block.settings.disclaimer_text }}</{{ disclaimer_tag }}>
                  {%- endif -%}
                {% endif %}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'button' -%}
          <div class="vso-hero-38__button-wrapper" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
            {% if block.settings.button_text != blank %}
              <a href="{{ block.settings.button_link | default: '#' }}" class="vso-hero-38__button">
                {{ block.settings.button_text }}
              </a>
            {% endif %}

            {% if block.settings.button_subtext != blank %}
              <div class="vso-hero-38__button-subtext-wrapper">
                {% if block.settings.subtext_icon != blank %}
                  <img
                    src="{{ block.settings.subtext_icon | image_url: width: 50 }}"
                    alt=""
                    class="vso-hero-38__button-subtext-icon"
                    width="50"
                    height="50"
                    loading="lazy"
                  >
                {% endif %}
                {%- if block.settings.button_subtext_custom_font -%}
                  <span class="vso-hero-38__button-subtext">{{ block.settings.button_subtext }}</span>
                {%- else -%}
                  {%- assign button_subtext_tag = block.settings.button_subtext_as | default: 'p' -%}
                  <{{ button_subtext_tag }} class="vso-hero-38__button-subtext">{{ block.settings.button_subtext }}</{{ button_subtext_tag }}>
                {%- endif -%}
              </div>
            {% endif %}
          </div>
        {%- endif -%}
      {%- endfor -%}

  </div>
</div>


{% if section.settings.enable_counter_animation %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var statsContainer = document.querySelector('#shopify-section-{{ section.id }} [data-animate-counters="true"]');
    if (!statsContainer) return;

    var animationDuration = 4000;
    var counters = statsContainer.querySelectorAll('[data-counter-target]');

    function animateCounter(counter, duration) {
      var target = parseInt(counter.getAttribute('data-counter-target'));
      if (isNaN(target) || target <= 0) return;
      var suffix = counter.getAttribute('data-counter-suffix') || '';
      var startTime = performance.now();

      function updateCounter(currentTime) {
        var elapsed = currentTime - startTime;
        var progress = Math.min(elapsed / duration, 1);
        var easedProgress = progress * (2 - progress);
        var currentValue = Math.round(easedProgress * target);
        counter.textContent = currentValue + suffix;
        if (progress < 1) {
          requestAnimationFrame(updateCounter);
        }
      }

      requestAnimationFrame(updateCounter);
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var counter = entry.target;
          if (!counter.hasAttribute('data-animated')) {
            counter.setAttribute('data-animated', 'true');
            animateCounter(counter, animationDuration);
          }
        }
      });
    }, {
      threshold: 0.5,
      rootMargin: '0px 0px -10% 0px'
    });

    counters.forEach(function(counter) {
      observer.observe(counter);
    });
  });
</script>
{% endif %}

{% schema %}
{
  "name": "VSO - Hero 38",
  "tag": "section",
  "class": "section vso-node vso-node--v2 vso-hero-38",
  "settings": [
    { "type": "header", "content": "Section Settings" },
    {
      "type": "checkbox",
      "id": "enable_advanced_settings",
      "label": "Enable advanced settings",
      "default": false,
      "info": "Shows additional settings for spacing, layout, and typography."
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Content max width",
      "min": 60,
      "max": 200,
      "step": 2,
      "unit": "rem",
      "default": 120,
      "visible_if": "{{ section.settings.enable_advanced_settings == true }}"
    },
    {
      "type": "range",
      "id": "section_horizontal_padding",
      "label": "Desktop side spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "info": "Adds spacing on the left and right sides of this section on desktop.",
      "visible_if": "{{ section.settings.enable_advanced_settings == true }}"
    },
    {
      "type": "range",
      "id": "section_horizontal_padding_mobile",
      "label": "Mobile side spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15,
      "info": "Adds spacing on the left and right sides of this section on mobile.",
      "visible_if": "{{ section.settings.enable_advanced_settings == true }}"
    },

    { "type": "header", "content": "Section Background" },
    {
      "type": "select",
      "id": "section_bg_type",
      "label": "Section background type",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "default": "solid",
      "info": "Background type for the section"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background color",
      "default": "#F5EFEA",
      "visible_if": "{{ section.settings.section_bg_type == 'solid' }}",
      "info": "Background color for the section"
    },
    {
      "type": "color_background",
      "id": "section_bg_gradient",
      "label": "Section background gradient",
      "default": "linear-gradient(180deg, #FFFFFF 0%, #F5F5F5 100%)",
      "visible_if": "{{ section.settings.section_bg_type == 'gradient' }}",
      "info": "Background gradient for the section"
    },
    {
      "type": "checkbox",
      "id": "full_width_desktop",
      "label": "Full width on desktop",
      "default": false,
      "info": "Make section background full width on desktop"
    },
    {
      "type": "range",
      "id": "section_border_radius",
      "label": "Desktop border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "section_border_radius_mobile",
      "label": "Mobile border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_border_width",
      "label": "Border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1,
      "visible_if": "{{ section.settings.enable_advanced_settings == true }}"
