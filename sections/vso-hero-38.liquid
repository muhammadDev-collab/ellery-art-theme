{%- endcomment -%}

{%- style -%}
  .vd-l { display: none !important; }
  #shopify-section-{{ section.id }} {
    --section-border-radius: {{ section.settings.section_border_radius_mobile }}px;
    --section-horizontal-padding: var(--page-margin, 16px);
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    border-radius: var(--section-border-radius);
    overflow: hidden;
  }

  {% if section.settings.enable_advanced_settings %}
    #shopify-section-{{ section.id }} {
      --section-horizontal-padding: {{ section.settings.section_horizontal_padding_mobile }}px;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      {% if section.settings.section_bg_type == 'gradient' %}
        background: {{ section.settings.section_bg_gradient }};
      {% else %}
        background-color: {{ section.settings.section_bg_color }};
      {% endif %}
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      --section-border-radius: {{ section.settings.section_border_radius }}px;
      --section-horizontal-padding: 0px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
      {% if section.settings.full_width_desktop %}
        {% if section.settings.section_bg_type == 'gradient' %}
          background: {{ section.settings.section_bg_gradient }};
        {% else %}
          background-color: {{ section.settings.section_bg_color }};
        {% endif %}
      {% endif %}
    }
  }

  {% if section.settings.enable_advanced_settings == false and section.settings.full_width_desktop == false %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        --section-horizontal-padding: 40px;
      }
    }
  {% endif %}

  {% if section.settings.enable_advanced_settings == false and section.settings.full_width_desktop %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        --section-container-max-width: var(--page-content-width, var(--page-width, 1440px));
        --section-outer-gutter: max(0px, calc((100vw - var(--section-container-max-width)) / 2));
        --section-horizontal-padding: max(0px, calc(var(--page-margin, 40px) - var(--section-outer-gutter)));
      }
    }
  {% endif %}

  {% if section.settings.enable_advanced_settings %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} {
        --section-horizontal-padding: {{ section.settings.section_horizontal_padding }}px;
      }
    }
  {% endif %}

  #shopify-section-{{ section.id }} > .vso-hero-38__container {
    margin-left: auto;
    margin-right: auto;
    max-width: var(--page-content-width, var(--page-width, 1440px));
    {% if section.settings.enable_advanced_settings %}
      max-width: {{ section.settings.section_max_width }}rem;
    {% endif %}
    border-radius: var(--section-border-radius);
    overflow: hidden;
    padding-left: var(--section-horizontal-padding);
    padding-right: var(--section-horizontal-padding);
    padding-top: {{ section.settings.section_padding_top_mobile }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_mobile }}px;
    border: 0;
    {% if section.settings.enable_advanced_settings %}
      border: {{ section.settings.section_border_width_mobile }}px solid {{ section.settings.section_border_color }};
    {% endif %}
  }

  {% if section.settings.full_width_desktop == false %}
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} > .vso-hero-38__container {
        width: calc(100% - (2 * var(--page-margin, 40px)));
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} > .vso-hero-38__container {
      background: transparent;
    }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} > .vso-hero-38__container {
      {% if section.settings.full_width_desktop %}
        background: transparent;
      {% else %}
        {% if section.settings.section_bg_type == 'gradient' %}
          background: {{ section.settings.section_bg_gradient }};
        {% else %}
          background-color: {{ section.settings.section_bg_color }};
        {% endif %}
      {% endif %}
      padding-top: {{ section.settings.section_padding_top }}px;
      padding-bottom: {{ section.settings.section_padding_bottom }}px;
      border: 0;
      {% if section.settings.enable_advanced_settings %}
        border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};
      {% endif %}
    }
  }

  #shopify-section-{{ section.id }} .vso-hero-38__content {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .vso-hero-38__middle-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.middle_section_gap_mobile }}px;
    align-items: start;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-hero-38__middle-section {
      grid-template-columns: 1fr 1fr;
      gap: {{ section.settings.middle_section_gap }}px;
    }
  }

  #shopify-section-{{ section.id }} .vso-hero-38__left-column {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .vso-hero-38__right-column {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .vso-hero-38__benefits-grid {
    display: grid;
    {% if section.settings.benefits_two_columns_mobile %}
      grid-template-columns: repeat(2, 1fr);
    {% else %}
      grid-template-columns: repeat({{ section.settings.benefits_columns_mobile }}, 1fr);
    {% endif %}
    gap: {{ section.settings.benefits_gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .vso-hero-38__benefits-grid {
      grid-template-columns: repeat({{ section.settings.benefits_columns }}, 1fr);
      gap: {{ section.settings.benefits_gap }}px;
    }
  }

  {% for block in section.blocks %}
    {% if block.type == 'heading' %}
      [data-block-id="{{ block.id }}"].vso-hero-38__heading-block {
        text-align: {{ block.settings.heading_alignment_mobile }};
        margin-top: {{ block.settings.margin_top_mobile }}px;
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"].vso-hero-38__heading-block {
          text-align: {{ block.settings.heading_alignment }};
          margin-top: {{ block.settings.margin_top }}px;
          margin-bottom: {{ block.settings.margin_bottom }}px;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__subheading {
        color: {{ block.settings.subheading_color }};
        margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
        {% if block.settings.subheading_custom_font %}
          font-size: {{ block.settings.subheading_font_size_mobile }}px;
          line-height: {{ block.settings.subheading_line_height }}%;
          font-family: {{ block.settings.subheading_font.family }}, {{ block.settings.subheading_font.fallback_families }};
          font-style: {{ block.settings.subheading_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.subheading_font_weight }};
            letter-spacing: {{ block.settings.subheading_letter_spacing }}px;
          {% endif %}
        {% endif %}
      }
      {% if block.settings.subheading_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__subheading {
            font-size: {{ block.settings.subheading_font_size }}px;
          }
        }
      {% endif %}

      [data-block-id="{{ block.id }}"] .vso-hero-38__heading {
        {% if block.settings.heading_color_type == 'gradient' %}
          background: {{ block.settings.heading_gradient }};
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
        {% else %}
          color: {{ block.settings.heading_color }};
        {% endif %}
        margin: 0;
        {% if block.settings.heading_custom_font %}
          font-size: {{ block.settings.heading_font_size_mobile }}px;
          line-height: {{ block.settings.heading_line_height }}%;
          font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
          font-style: {{ block.settings.heading_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.heading_font_weight }};
            letter-spacing: {{ block.settings.heading_letter_spacing }}px;
          {% endif %}
        {% endif %}
      }
      {% if block.settings.heading_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__heading {
            font-size: {{ block.settings.heading_font_size }}px;
          }
        }
      {% endif %}
    {% endif %}

    {% if block.type == 'paragraph' %}
      [data-block-id="{{ block.id }}"].vso-hero-38__paragraph {
        text-align: {{ block.settings.paragraph_alignment_mobile }};
        margin-top: {{ block.settings.margin_top_mobile }}px;
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"].vso-hero-38__paragraph {
          text-align: {{ block.settings.paragraph_alignment }};
          margin-top: {{ block.settings.margin_top }}px;
          margin-bottom: {{ block.settings.margin_bottom }}px;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__paragraph-text {
        color: {{ block.settings.paragraph_color }};
        margin: 0;
        {% if block.settings.paragraph_custom_font %}
          font-size: {{ block.settings.paragraph_font_size_mobile }}px;
          line-height: {{ block.settings.paragraph_line_height }}%;
          font-family: {{ block.settings.paragraph_font.family }}, {{ block.settings.paragraph_font.fallback_families }};
          font-style: {{ block.settings.paragraph_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.paragraph_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if block.settings.paragraph_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__paragraph-text {
            font-size: {{ block.settings.paragraph_font_size }}px;
          }
        }
      {% endif %}
    {% endif %}

    {% if block.type == 'testimonial' %}
      [data-block-id="{{ block.id }}"].vso-hero-38__testimonial {
        background-color: {{ block.settings.testimonial_bg_color }};
        border: {{ block.settings.testimonial_border_width }}px solid {{ block.settings.testimonial_border_color }};
        border-radius: {{ block.settings.testimonial_border_radius_mobile }}px;
        padding: 0;
        margin-top: {{ block.settings.margin_top_mobile }}px;
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
        display: flex;
        flex-direction: column;
        gap: 0;
        overflow: hidden;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"].vso-hero-38__testimonial {
          border-radius: {{ block.settings.testimonial_border_radius }}px;
          padding: 0;
          margin-top: {{ block.settings.margin_top }}px;
          margin-bottom: {{ block.settings.margin_bottom }}px;
          flex-direction: row;
          align-items: stretch;
          overflow: hidden;
          gap: {{ block.settings.testimonial_gap }}px;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-media {
        width: 100%;
        border-radius: 0;
        overflow: hidden;
        flex-shrink: 0;
        display: block;
        line-height: 0;
        font-size: 0;
        position: relative;
      }
      @media screen and (max-width: 749px) {
        [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-media {
          height: {{ block.settings.mobile_image_height | default: 180 }}px;
        }
      }
      [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-media picture {
        display: block;
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-media {
          flex: 0 0 30%;
          align-self: stretch;
          height: auto;
          min-height: 100%;
          line-height: 0;
          font-size: 0;
          display: block;
          position: relative;
        }
        [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-media picture {
          display: block;
          width: 100%;
          height: 100%;
          position: absolute;
          top: 0;
          left: 0;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-content {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: {{ block.settings.testimonial_padding_mobile }}px;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-content {
          padding: {{ block.settings.testimonial_padding }}px;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-quote {
        color: {{ block.settings.quote_color }};
        margin: 0;
        {% if block.settings.quote_custom_font %}
          font-size: {{ block.settings.quote_font_size_mobile }}px;
          line-height: {{ block.settings.quote_line_height }}%;
          font-family: {{ block.settings.quote_font.family }}, {{ block.settings.quote_font.fallback_families }};
          font-style: {{ block.settings.quote_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.quote_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if block.settings.quote_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-quote {
            font-size: {{ block.settings.quote_font_size }}px;
          }
        }
      {% endif %}

      [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-author {
        color: {{ block.settings.author_color }};
        margin: 0;
        {% if block.settings.author_custom_font %}
          font-size: {{ block.settings.author_font_size_mobile }}px;
          line-height: {{ block.settings.author_line_height }}%;
          font-family: {{ block.settings.author_font.family }}, {{ block.settings.author_font.fallback_families }};
          font-style: {{ block.settings.author_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.author_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if block.settings.author_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__testimonial-author {
            font-size: {{ block.settings.author_font_size }}px;
          }
        }
      {% endif %}

      [data-block-id="{{ block.id }}"] .vso-hero-38__verified-badge {
        display: flex;
        align-items: center;
        gap: {{ block.settings.badge_gap }}px;
        color: {{ block.settings.badge_color }};
        {% if block.settings.badge_custom_font %}
          font-size: {{ block.settings.badge_font_size_mobile }}px;
          line-height: {{ block.settings.badge_line_height }}%;
          font-family: {{ block.settings.badge_font.family }}, {{ block.settings.badge_font.fallback_families }};
          font-style: {{ block.settings.badge_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.badge_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if block.settings.badge_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__verified-badge {
            font-size: {{ block.settings.badge_font_size }}px;
          }
        }
      {% endif %}

      [data-block-id="{{ block.id }}"] .vso-hero-38__verified-badge > * {
        margin: 0;
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__verified-icon {
        width: {{ block.settings.badge_icon_size }}px;
        height: {{ block.settings.badge_icon_size }}px;
        flex-shrink: 0;
        fill: {{ block.settings.badge_icon_color }};
      }
    {% endif %}

    {% if block.type == 'benefit' %}
      [data-block-id="{{ block.id }}"].vso-hero-38__benefit {
        display: flex;
        flex-direction: column;
        gap: {{ section.settings.benefit_element_gap }}px;
        text-align: {{ section.settings.benefit_alignment_mobile }};
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"].vso-hero-38__benefit {
          text-align: {{ section.settings.benefit_alignment }};
          margin-bottom: {{ block.settings.margin_bottom }}px;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__benefit-number {
        {% if section.settings.benefit_number_color_type == 'gradient' %}
          background: {{ section.settings.benefit_number_gradient }};
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
        {% else %}
          color: {{ section.settings.benefit_number_color }};
        {% endif %}
        margin: 0;
        {% if section.settings.enable_counter_animation %}
          font-variant-numeric: tabular-nums;
        {% endif %}
        {% if section.settings.benefit_number_custom_font %}
          font-size: {{ section.settings.benefit_number_font_size_mobile }}px;
          line-height: {{ section.settings.benefit_number_line_height }}%;
          font-family: {{ section.settings.benefit_number_font.family }}, {{ section.settings.benefit_number_font.fallback_families }};
          font-style: {{ section.settings.benefit_number_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ section.settings.benefit_number_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if section.settings.benefit_number_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__benefit-number {
            font-size: {{ section.settings.benefit_number_font_size }}px;
          }
        }
      {% endif %}

      [data-block-id="{{ block.id }}"] .vso-hero-38__benefit-text {
        color: {{ section.settings.benefit_text_color }};
        margin: 0;
        {% if section.settings.benefit_text_custom_font %}
          font-size: {{ section.settings.benefit_text_font_size_mobile }}px;
          line-height: {{ section.settings.benefit_text_line_height }}%;
          font-family: {{ section.settings.benefit_text_font.family }}, {{ section.settings.benefit_text_font.fallback_families }};
          font-style: {{ section.settings.benefit_text_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ section.settings.benefit_text_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if section.settings.benefit_text_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__benefit-text {
            font-size: {{ section.settings.benefit_text_font_size }}px;
          }
        }
      {% endif %}
    {% endif %}

    {% if block.type == 'disclaimer' %}
      [data-block-id="{{ block.id }}"].vso-hero-38__disclaimer {
        text-align: {{ block.settings.disclaimer_alignment_mobile }};
        margin-top: {{ block.settings.margin_top_mobile }}px;
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"].vso-hero-38__disclaimer {
          text-align: {{ block.settings.disclaimer_alignment }};
          margin-top: {{ block.settings.margin_top }}px;
          margin-bottom: {{ block.settings.margin_bottom }}px;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__disclaimer-text {
        color: {{ block.settings.disclaimer_color }};
        margin: 0;
        font-style: italic;
        {% if block.settings.disclaimer_custom_font %}
          font-size: {{ block.settings.disclaimer_font_size_mobile }}px;
          line-height: {{ block.settings.disclaimer_line_height }}%;
          font-family: {{ block.settings.disclaimer_font.family }}, {{ block.settings.disclaimer_font.fallback_families }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.disclaimer_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if block.settings.disclaimer_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__disclaimer-text {
            font-size: {{ block.settings.disclaimer_font_size }}px;
          }
        }
      {% endif %}
    {% endif %}

    {% if block.type == 'button' %}
      [data-block-id="{{ block.id }}"].vso-hero-38__button-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: {{ block.settings.button_subtext_spacing }}px;
        text-align: center;
        margin-top: {{ block.settings.margin_top_mobile }}px;
        margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
      }
      @media screen and (min-width: 750px) {
        [data-block-id="{{ block.id }}"].vso-hero-38__button-wrapper {
          margin-top: {{ block.settings.margin_top }}px;
          margin-bottom: {{ block.settings.margin_bottom }}px;
        }
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: {{ block.settings.button_padding_vertical_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px;
        background-color: {{ block.settings.button_bg_color }};
        color: {{ block.settings.button_text_color }};
        text-decoration: none;
        border-radius: {{ block.settings.button_border_radius }}px;
        border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
        transition: all 0.3s ease;
        cursor: pointer;
        {% if block.settings.button_custom_font %}
          font-size: {{ block.settings.button_font_size_mobile }}px;
          line-height: {{ block.settings.button_line_height }}%;
          font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
          font-style: {{ block.settings.button_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.button_font_weight }};
            letter-spacing: {{ block.settings.button_letter_spacing }}px;
          {% endif %}
        {% endif %}
      }
      {% if block.settings.button_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__button {
            font-size: {{ block.settings.button_font_size }}px;
            padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
          }
        }
      {% endif %}

      [data-block-id="{{ block.id }}"] .vso-hero-38__button:hover {
        background-color: {{ block.settings.button_bg_color_hover }};
        color: {{ block.settings.button_text_color_hover }};
        border-color: {{ block.settings.button_border_color_hover }};
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__button-subtext-wrapper {
        display: flex;
        align-items: center;
        gap: {{ block.settings.subtext_icon_gap }}px;
        justify-content: center;
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__button-subtext-icon {
        width: {{ block.settings.subtext_icon_size }}px;
        height: {{ block.settings.subtext_icon_size }}px;
        flex-shrink: 0;
      }

      [data-block-id="{{ block.id }}"] .vso-hero-38__button-subtext {
        color: {{ block.settings.button_subtext_color }};
        margin: 0;
        {% if block.settings.button_subtext_custom_font %}
          font-size: {{ block.settings.button_subtext_font_size_mobile }}px;
          line-height: {{ block.settings.button_subtext_line_height }}%;
          font-family: {{ block.settings.button_subtext_font.family }}, {{ block.settings.button_subtext_font.fallback_families }};
          font-style: {{ block.settings.button_subtext_font.style }};
          {% if section.settings.enable_advanced_settings %}
            font-weight: {{ block.settings.button_subtext_font_weight }};
          {% endif %}
        {% endif %}
      }
      {% if block.settings.button_subtext_custom_font %}
        @media screen and (min-width: 750px) {
          [data-block-id="{{ block.id }}"] .vso-hero-38__button-subtext {
            font-size: {{ block.settings.button_subtext_font_size }}px;
          }
        }
      {% endif %}
    {% endif %}
  {% endfor %}

  #shopify-section-{{ section.id }} .vso-node { display: none; }
  #shopify-section-{{ section.id }} .vso-node--v2 { display: block; }

  /* Concept theme compatibility: prevent global reveal styles from hiding the section */
  #shopify-section-{{ section.id }}.vso-node--v2 {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    position: relative !important;
    z-index: 1 !important;
  }

  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__container,
  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__content,
  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__middle-section,
  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__left-column,
  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__right-column,
  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__heading,
  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__subheading,
  #shopify-section-{{ section.id }}.vso-node--v2 .vso-hero-38__paragraph-text {
    opacity: 1 !important;
    visibility: visible !important;
  }
{%- endstyle -%}

