{%- liquid
  assign free_shipping_threshold = settings.free_shipping_threshold | times: 100
  assign cart_total = cart.total_price
  assign remaining = free_shipping_threshold | minus: cart_total
-%}

{%- if free_shipping_threshold > 0 -%}
  <div class="cart-free-shipping">
    {%- if remaining > 0 -%}
      <p class="cart-free-shipping__text">
        You're <strong>{{ remaining | money_without_trailing_zeros }}</strong> away from free shipping!
      </p>
      <div class="cart-free-shipping__bar-track">
        {%- assign progress = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
        <div class="cart-free-shipping__bar-fill" style="width: {{ progress | at_most: 100 }}%"></div>
      </div>
    {%- else -%}
      <p class="cart-free-shipping__text cart-free-shipping__text--achieved">
        🎉 You've unlocked <strong>free shipping!</strong>
      </p>
      <div class="cart-free-shipping__bar-track">
        <div class="cart-free-shipping__bar-fill" style="width: 100%"></div>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

<style>
  .cart-free-shipping {
    background: #ffffff;
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cart-free-shipping__text {
    font-size: 12px;
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }
  .cart-free-shipping__text--achieved {
    color: #2a7a4b;
  }
  .cart-free-shipping__bar-track {
    width: 100%;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
    overflow: hidden;
  }
  .cart-free-shipping__bar-fill {
    height: 100%;
    background: #001bcf;
    border-radius: 2px;
    transition: width 0.4s ease;
  }
</style>
