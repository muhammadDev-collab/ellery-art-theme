<!-- Link the custom CSS file -->
<link rel="stylesheet" href="{{ 'custom-progress-bar.css' | asset_url }}">

{% if type == 'cart' %}
  <style>
    .discount-app-{{ type }}.progress-bar-main {
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: #f2efeb;
      flex-direction: column;
      height: 55px;
      row-gap: 4px;
      margin-left: auto;
      margin-right: auto;
      margin-top: -5px;
      max-width: 530px;
    }
  </style>
{% elsif type == 'cart-drawer' %}
  <style>
    .discount-app-{{ type }}.progress-bar-main {
      position: sticky;
      top: 0;
      left: 0;
      z-index: 5;
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: white;
      flex-direction: column;
      height: 55px;
      row-gap: 4px;
      border-radius: 3px;
    }
    .discount-app-{{ type }}.progress-bar-main .progress-container {
      display: none;
    }
    .discount-app-{{ type }}.progress-bar-main #progress-description-text {
      font-size: inherit;
    }
    .discount-app-{{ type }}.progress-bar-main .progress-description {
      width: 95%;
    }
    @media screen and (max-width: 641px) {
      .discount-app-{{ type }}.progress-bar-main #progress-description-text {
        font-size: 13px;
      }
    }
  </style>
{% else %}
  <style>
    .discount-app-{{ type }}.progress-bar-main {
      position: sticky;
      top: 0;
      left: 0;
      z-index: 5;
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: #f5f2eb;
      flex-direction: column;
      height: 55px;
      row-gap: 4px;
    }
    .discount-app-{{ type }}.progress-bar-main ~ .shopify-section--header {
      top: 55px;
    }
  </style>
{% endif %}

{% comment %} main progress bar {% endcomment %}
<div class="discount-app-{{ type }} progress-bar-main">
  <div class="progress-description">
    <p id="progress-description-text"></p>
    <img
      id="ask-about-discount"
      class="question-icon hide"
      src="{{ 'question-mark.svg' | asset_url }}"
      alt="i" />
  </div>
  <div id="progress-container" class="progress-container hide">
    <div class="line">
      <div class="progress"></div>
    </div>
    <div class="circle blue">
      <span class="circle_inner_text">&#10003;</span>
    </div>
    <div class="circle">
      <span class="circle_inner_text">&#10003;</span>
    </div>
    <div class="circle special">+1</div>
    <div class="circle">
      <span class="circle_inner_text">&#10003;</span>
    </div>
    <div class="circle special">+2</div>
  </div>
</div>

{%- assign translations = metaobjects["discount_offer_bar_translations"]['discount-offer-bar-translations'] -%}
{%- assign step_0 = translations['step_1'].value -%}
{%- assign step_1 = translations['step_2'].value -%}
{%- assign step_2 = translations['step_3'].value -%}
{%- assign step_3 = translations['step_4'].value -%}
{%- assign step_4 = translations['step_5'].value -%}
{%- assign step_5 = translations['step_6'].value -%}

<script>
  (function () {
    // Expose collection handle globally once
    {% if settings.discounted_collection != blank %}
      window.discountedCollectionHandle = "{{ settings.discounted_collection.handle }}";
    {% endif %}

    var TYPE = {{ type | json }};

    var circles         = document.querySelectorAll('.discount-app-' + TYPE + ' .circle');
    var progressLine    = document.querySelector('.discount-app-' + TYPE + ' .line .progress');
    var progressContainer = document.querySelector('.discount-app-' + TYPE + ' #progress-container');
    var progressDescription = document.querySelector('.discount-app-' + TYPE + ' #progress-description-text');
    var askAboutDiscount = document.querySelector('.discount-app-' + TYPE + ' #ask-about-discount');

    var maxCartItems = 5;
    var stepProgress = [0, 15, 38, 64, 87, 100];

    var stepDescriptions = [
      "{{ step_0 | escape }}",
      "{{ step_1 | escape }}",
      "{{ step_2 | escape }}",
      "{{ step_3 | escape }}",
      "{{ step_4 | escape }}",
      "{{ step_5 | escape }}"
    ];

    function updateProgressBar(cartCount) {
      var step = Math.min(cartCount, maxCartItems);

      circles.forEach(function (circle, index) {
        if (index < step) {
          circle.classList.add('blue');
          if (circle.classList.contains('special')) {
            circle.innerHTML = '<span>&#10003;</span>';
          }
        } else {
          circle.classList.remove('blue');
          if (circle.classList.contains('special')) {
            circle.innerHTML = index === 2 ? '+1' : '+2';
          }
        }
      });

      if (progressLine) progressLine.style.width = stepProgress[step] + '%';
      if (progressDescription) progressDescription.textContent = stepDescriptions[step];

      if (askAboutDiscount) {
        askAboutDiscount.classList.remove('hide');
        askAboutDiscount.classList.add('show');
      }

      if (progressContainer) {
        if (cartCount > 0) {
          progressContainer.classList.remove('hide');
          progressContainer.classList.add('show');
        } else {
          progressContainer.classList.remove('show');
          progressContainer.classList.add('hide');
        }
      }
    }

    function fetchDiscountCollection(handle) {
      var cacheKey       = 'discountCollection_' + handle;
      var cacheExpiryKey = 'discountCollectionExpiry_' + handle;
      var cached         = localStorage.getItem(cacheKey);
      var expiry         = localStorage.getItem(cacheExpiryKey);
      var now            = Date.now();

      if (cached && expiry && now < parseInt(expiry, 10)) {
        return Promise.resolve(JSON.parse(cached));
      }

      function fetchPage(page, accumulated) {
        return fetch('/collections/' + handle + '/products.json?page=' + page + '&limit=250')
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var ids = accumulated.concat(data.products.map(function (p) { return p.id; }));
            if (data.products.length < 250) {
              localStorage.setItem(cacheKey, JSON.stringify(ids));
              localStorage.setItem(cacheExpiryKey, now + 3600 * 1000);
              return ids;
            }
            return fetchPage(page + 1, ids);
          });
      }

      return fetchPage(1, []).catch(function (e) { console.error('Error fetching collection:', e); return []; });
    }

    function fetchCart() {
      return fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .catch(function (e) { console.error('Error fetching cart:', e); return { items: [] }; });
    }

    function countEligibleProducts(cart, productIds) {
      var count = 0;
      cart.items.forEach(function (item) {
        if (productIds.indexOf(item.product_id) !== -1) {
          count += item.quantity;
        }
      });
      return count;
    }

    function checkCartForDiscounts() {
      var handle = window.discountedCollectionHandle;
      if (!handle) return;

      Promise.all([fetchDiscountCollection(handle), fetchCart()])
        .then(function (results) {
          var eligibleCount = countEligibleProducts(results[1], results[0]);
          updateProgressBar(eligibleCount);
        })
        .catch(function (e) { console.error('Error checking cart discounts:', e); });
    }

    // Run on page load
    document.addEventListener('DOMContentLoaded', function () {
      checkCartForDiscounts();
    });

    // Listen to Shopify / theme cart update events
    document.addEventListener('cart:updated', checkCartForDiscounts);
    document.addEventListener('cart:refresh', checkCartForDiscounts);

    // Theme-specific: Prestige emits these custom events on cart change
    document.addEventListener('cart-drawer:open', checkCartForDiscounts);
    document.addEventListener('variant:changed', checkCartForDiscounts);

    // Also poll via fetch after any add-to-cart form submit
    document.addEventListener('submit', function (e) {
      var form = e.target;
      if (form && (form.action || '').indexOf('/cart/add') !== -1) {
        setTimeout(checkCartForDiscounts, 800);
      }
    });

    // Ask about discount icon click
    document.addEventListener('click', function (e) {
      if (e.target && e.target.id === 'ask-about-discount') {
        var popup = document.querySelector('.discount-info-popup');
        if (popup) popup.classList.add('visible');
      }
    });
  })();
</script>
