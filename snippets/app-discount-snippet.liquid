<!-- Link the custom CSS file -->
<link rel="stylesheet" href="{{ 'custom-progress-bar.css' | asset_url }}">

{% if type == 'cart' %}
  <style>
    .discount-app-{{ type }}.progress-bar-main {
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: #f2efeb;
      flex-direction: column;
      height: 55px;
      row-gap: 4px;
      margin-left: auto;
      margin-right: auto;
      margin-top: -5px;
      max-width: 530px;
    }
  </style>
{% elsif type == 'cart-drawer' %}
  <style>
    .discount-app-{{ type }}.progress-bar-main {
      position: sticky;
      top: 0;
      left: 0;
      z-index: 5;
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: white;
      flex-direction: column;
      height: 55px;
      row-gap: 4px;
      border-radius: 3px;
    }
    .discount-app-{{ type }}.progress-bar-main .progress-description-text {
      font-size: inherit;
    }
    .discount-app-{{ type }}.progress-bar-main .progress-description {
      width: 95%;
    }
    @media screen and (max-width: 641px) {
      .discount-app-{{ type }}.progress-bar-main .progress-description-text {
        font-size: 13px;
      }
    }
  </style>
{% else %}
  <style>
    .discount-app-{{ type }}.progress-bar-main {
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: #f5f2eb;
      flex-direction: column;
      height: 55px;
      row-gap: 4px;
    }
  </style>
{% endif %}

{% comment %} main progress bar {% endcomment %}
<div class="discount-app-{{ type }} progress-bar-main">
  <div class="progress-description">
    <p class="progress-description-text"></p>
    <img
      class="ask-about-discount question-icon hide"
      src="{{ 'question-mark.svg' | asset_url }}"
      alt="i" />
  </div>
  <div class="progress-container hide">
    <div class="line">
      <div class="progress"></div>
    </div>
    <div class="circle blue">
      <span class="circle_inner_text">&#10003;</span>
    </div>
    <div class="circle">
      <span class="circle_inner_text">&#10003;</span>
    </div>
    <div class="circle special">+1</div>
    <div class="circle">
      <span class="circle_inner_text">&#10003;</span>
    </div>
    <div class="circle special">+2</div>
  </div>
</div>

{%- assign translations = metaobjects["discount_offer_bar_translations"]['discount-offer-bar-translations'] -%}
{%- assign step_0 = translations['step_1'].value -%}
{%- assign step_1 = translations['step_2'].value -%}
{%- assign step_2 = translations['step_3'].value -%}
{%- assign step_3 = translations['step_4'].value -%}
{%- assign step_4 = translations['step_5'].value -%}
{%- assign step_5 = translations['step_6'].value -%}

<script>
  (function () {
    var TYPE = {{ type | json }};

    var stepDescriptions = [
      "{{ step_0 | escape }}",
      "{{ step_1 | escape }}",
      "{{ step_2 | escape }}",
      "{{ step_3 | escape }}",
      "{{ step_4 | escape }}",
      "{{ step_5 | escape }}"
    ];

    // ── Expose collection handle globally once ──────────────────────────────
    {% if settings.discounted_collection != blank %}
      window.discountedCollectionHandle = "{{ settings.discounted_collection.handle }}";
    {% endif %}

    // ── Set header CSS custom property for sticky offset ───────────────────
    if (TYPE === 'header') {
      function setBarHeight() {
        var barEl = document.querySelector('.discount-app-header.progress-bar-main');
        var h = barEl ? barEl.getBoundingClientRect().height : 55;
        document.documentElement.style.setProperty('--discount-progress-bar-height', h + 'px');
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setBarHeight);
      } else {
        setBarHeight();
      }
      window.addEventListener('resize', setBarHeight);
    }

    // ── Shared global controller ────────────────────────────────────────────
    // All instances (header, cart-drawer, cart) share one controller so that
    // a single cart change updates every bar simultaneously.
    if (!window.discountProgressBarCtrl) {
      window.discountProgressBarCtrl = {
        maxCartItems : 5,
        stepProgress : [0, 15, 38, 64, 87, 100],
        // Map of TYPE → stepDescriptions array, populated as each snippet loads
        descriptions : {},

        // Update a single bar identified by its TYPE string
        updateOne: function (type, step) {
          var descs     = this.descriptions[type] || [];
          var circles   = document.querySelectorAll('.discount-app-' + type + ' .circle');
          var line      = document.querySelector('.discount-app-' + type + ' .line .progress');
          var container = document.querySelector('.discount-app-' + type + ' .progress-container');
          var descEl    = document.querySelector('.discount-app-' + type + ' .progress-description-text');
          var iconEl    = document.querySelector('.discount-app-' + type + ' .ask-about-discount');

          circles.forEach(function (circle, index) {
            if (index < step) {
              circle.classList.add('blue');
              if (circle.classList.contains('special')) {
                circle.innerHTML = '<span>&#10003;</span>';
              }
            } else {
              circle.classList.remove('blue');
              if (circle.classList.contains('special')) {
                circle.innerHTML = index === 2 ? '+1' : '+2';
              }
            }
          });

          if (line)    line.style.width = this.stepProgress[step] + '%';
          if (descEl)  descEl.textContent = descs[step] || '';
          if (iconEl)  { iconEl.classList.remove('hide'); iconEl.classList.add('show'); }

          if (container) {
            if (step > 0) {
              container.classList.remove('hide'); container.classList.add('show');
            } else {
              container.classList.remove('show'); container.classList.add('hide');
            }
          }
        },

        // Update ALL registered bars with the same cart count
        updateAll: function (cartCount) {
          var step = Math.min(cartCount, this.maxCartItems);
          var self = this;
          Object.keys(this.descriptions).forEach(function (type) {
            self.updateOne(type, step);
          });
        },

        // Fetch the discounted collection product IDs (cached 1 hour)
        fetchCollection: function (handle) {
          var cacheKey    = 'discountCollection_' + handle;
          var expiryKey   = 'discountCollectionExpiry_' + handle;
          var cached      = localStorage.getItem(cacheKey);
          var expiry      = localStorage.getItem(expiryKey);
          var now         = Date.now();

          if (cached && expiry && now < parseInt(expiry, 10)) {
            return Promise.resolve(JSON.parse(cached));
          }

          var self = this;
          function fetchPage(page, acc) {
            return fetch('/collections/' + handle + '/products.json?page=' + page + '&limit=250')
              .then(function (r) { return r.json(); })
              .then(function (data) {
                var ids = acc.concat(data.products.map(function (p) { return p.id; }));
                if (data.products.length < 250) {
                  localStorage.setItem(cacheKey, JSON.stringify(ids));
                  localStorage.setItem(expiryKey, String(now + 3600 * 1000));
                  return ids;
                }
                return fetchPage(page + 1, ids);
              });
          }
          return fetchPage(1, []).catch(function (e) { console.error('Discount collection fetch error:', e); return []; });
        },

        // Fetch the live cart
        fetchCart: function () {
          return fetch('/cart.js')
            .then(function (r) { return r.json(); })
            .catch(function (e) { console.error('Cart fetch error:', e); return { items: [] }; });
        },

        // Count eligible items in cart
        countEligible: function (cart, productIds) {
          var count = 0;
          cart.items.forEach(function (item) {
            if (productIds.indexOf(item.product_id) !== -1) count += item.quantity;
          });
          return count;
        },

        // Main refresh — fetches cart + collection then updates ALL bars
        refresh: function () {
          var handle = window.discountedCollectionHandle;
          if (!handle) return;
          var self = this;
          Promise.all([self.fetchCollection(handle), self.fetchCart()])
            .then(function (results) {
              self.updateAll(self.countEligible(results[1], results[0]));
            })
            .catch(function (e) { console.error('Discount bar refresh error:', e); });
        },

        // Attach global event listeners exactly once
        _listenersAttached: false,
        attachListeners: function () {
          if (this._listenersAttached) return;
          this._listenersAttached = true;
          var self = this;

          var refresh = function () { self.refresh(); };

          document.addEventListener('cart:updated',     refresh);
          document.addEventListener('cart:refresh',     refresh);
          document.addEventListener('cart-drawer:open', refresh);
          document.addEventListener('variant:changed',  refresh);

          document.addEventListener('submit', function (e) {
            var form = e.target;
            if (form && (form.action || '').indexOf('/cart/add') !== -1) {
              setTimeout(refresh, 800);
            }
          });
        }
      };
    }

    // Register this instance's descriptions and kick off listeners + initial refresh
    var ctrl = window.discountProgressBarCtrl;
    ctrl.descriptions[TYPE] = stepDescriptions;
    ctrl.attachListeners();

    // Run initial refresh once DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { ctrl.refresh(); });
    } else {
      ctrl.refresh();
    }

  })();
</script>
