{% doc %}
  @prompt
    Create a Shopify section that looks like a premium USP / trust bar.
    
    Layout:
    
    * A full-width horizontal bar.
    * 3 equal columns on desktop.
    * 1 column per row or stacked layout on mobile.
    * Each column should contain:
    
      * an icon
      * a short text line
    * Add thin vertical divider lines between the columns on desktop only.
    
    Style:
    
    * Black background by default.
    * White or light gray text by default.
    * Clean, minimal, premium ecommerce style.
    * Content should be vertically and horizontally centered.
    * Compact height, like a slim trust bar.
    * No large padding or empty space.
    
    Customization:
    
    * Each column must be editable separately in the Shopify theme editor.
    * For each column, allow:
    
      * custom icon
      * custom text
      * text color
      * icon color if possible
    * Global settings:
    
      * background color
      * divider color
      * desktop height
      * mobile height
      * font size desktop
      * font size mobile
      * spacing between icon and text
    
    Important:
    
    * Make all 3 items balanced and aligned.
    * Keep the bar tight and compact.
    * Make it responsive and clean on mobile.
    * Use blocks so I can add, remove, or reorder items later.
    
    Default example content:
    
    1. Icon: badge / seal
       Text: "Officially Licensed Artworks Only"
    
    2. Icon: truck
       Text: "Free Shipping on All Orders Above 950 kr"
    
    3. Icon: shield / secure
       Text: "100% Safe and Secure Transactions"
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-usp-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: 0;
  }

  .ai-usp-bar-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: center;
    width: 100%;
    margin: 0 auto;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-usp-bar-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.icon_text_spacing }}px;
    padding: 12px 20px;
    position: relative;
    height: 100%;
  }

  .ai-usp-bar-item-{{ ai_gen_id }}:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 60%;
    background-color: {{ block.settings.divider_color }};
  }

  .ai-usp-bar-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-usp-bar-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-usp-bar-icon-{{ ai_gen_id }}.icon-1 svg {
    stroke: {{ block.settings.icon_color_1 }};
    fill: none;
  }

  .ai-usp-bar-icon-{{ ai_gen_id }}.icon-2 svg {
    stroke: {{ block.settings.icon_color_2 }};
    fill: none;
  }

  .ai-usp-bar-icon-{{ ai_gen_id }}.icon-3 svg {
    stroke: {{ block.settings.icon_color_3 }};
    fill: none;
  }

  .ai-usp-bar-text-{{ ai_gen_id }}.text-1 {
    color: {{ block.settings.text_color_1 }};
    font-size: {{ block.settings.font_size_desktop }}px;
    line-height: 1.3;
    margin: 0;
    white-space: nowrap;
  }

  .ai-usp-bar-text-{{ ai_gen_id }}.text-2 {
    color: {{ block.settings.text_color_2 }};
    font-size: {{ block.settings.font_size_desktop }}px;
    line-height: 1.3;
    margin: 0;
    white-space: nowrap;
  }

  .ai-usp-bar-text-{{ ai_gen_id }}.text-3 {
    color: {{ block.settings.text_color_3 }};
    font-size: {{ block.settings.font_size_desktop }}px;
    line-height: 1.3;
    margin: 0;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-usp-bar-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      height: auto;
    }

    .ai-usp-bar-item-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_height }}px 20px;
      border-bottom: 1px solid {{ block.settings.divider_color }};
    }

    .ai-usp-bar-item-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }

    .ai-usp-bar-item-{{ ai_gen_id }}::after {
      display: none;
    }

    .ai-usp-bar-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
      white-space: normal;
      text-align: center;
    }
  }
{% endstyle %}

<div class="ai-usp-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-usp-bar-container-{{ ai_gen_id }}">
    <div class="ai-usp-bar-item-{{ ai_gen_id }}">
      <div class="ai-usp-bar-icon-{{ ai_gen_id }} icon-1">
        {% if block.settings.icon_type_1 == 'badge' %}
