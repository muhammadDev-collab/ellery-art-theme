{% doc %}
  @prompt
    Create a brand new Shopify section from scratch.
    
    I want a fully customizable trust / USP bar section built with Shopify blocks.
    
    Important:
    
    * Do not base it on the previous section.
    * Build it as a new clean section from scratch.
    * Make it fully editable in the Shopify theme editor.
    
    Section purpose:
    
    * A premium trust bar with multiple items in one row.
    * Each item should have an icon and a short text.
    * The section should look clean, minimal, compact, and premium.
    
    Structure:
    
    * Use blocks for the trust items.
    * Each block should be repeatable so I can add, remove, and reorder items.
    * Show the blocks in a horizontal row on desktop.
    * Stack them vertically on mobile.
    
    Each block must have separate settings for:
    
    * icon or image
    * text
    * text color
    * icon color
    * icon size
    * font size
    * font weight
    * optional link
    
    Section settings must include:
    
    * background color
    * content width
    * divider on/off
    * divider color
    * divider thickness
    * spacing between items
    * spacing between icon and text
    * desktop padding top/bottom
    * mobile padding top/bottom
    * horizontal alignment
    * vertical alignment
    
    Design requirements:
    
    * compact height
    * no large empty spaces
    * clean vertical centering
    * thin divider lines between items on desktop only
    * responsive and clean on mobile
    * premium ecommerce style
    
    Default example blocks:
    
    1. Officially Licensed Artworks Only
    2. Free Shipping on All Orders Above 950 kr
    3. 100% Safe and Secure Transactions
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.desktop_padding_top }}px;
    padding-bottom: {{ block.settings.desktop_padding_bottom }}px;
  }

  .ai-trust-bar__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-trust-bar__items-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    justify-content: {{ block.settings.horizontal_alignment }};
    gap: {{ block.settings.spacing_between_items }}px;
    flex-wrap: nowrap;
  }

  .ai-trust-bar__item-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.spacing_icon_text }}px;
    flex: 0 1 auto;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ai-trust-bar__item-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-trust-bar__item-{{ ai_gen_id }}:not(:last-child) {
    {% if block.settings.show_divider %}
      padding-right: {{ block.settings.spacing_between_items }}px;
      border-right: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
    {% endif %}
  }

  .ai-trust-bar__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-bar__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_1 }}px;
    height: {{ block.settings.icon_size_1 }}px;
    object-fit: contain;
  }

  .ai-trust-bar__icon-svg-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_1 }}px;
    height: {{ block.settings.icon_size_1 }}px;
  }

  .ai-trust-bar__icon-svg-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color_1 }};
    fill: none;
  }

  .ai-trust-bar__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color_1 }};
    font-size: {{ block.settings.font_size_1 }}px;
    font-weight: {{ block.settings.font_weight_1 }};
    margin: 0;
    line-height: 1.3;
    white-space: nowrap;
  }

  .ai-trust-bar__icon-2-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_2 }}px;
    height: {{ block.settings.icon_size_2 }}px;
  }

  .ai-trust-bar__icon-svg-2-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_2 }}px;
    height: {{ block.settings.icon_size_2 }}px;
  }

  .ai-trust-bar__icon-svg-2-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color_2 }};
    fill: none;
  }

  .ai-trust-bar__text-2-{{ ai_gen_id }} {
    color: {{ block.settings.text_color_2 }};
    font-size: {{ block.settings.font_size_2 }}px;
    font-weight: {{ block.settings.font_weight_2 }};
  }

  .ai-trust-bar__icon-3-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_3 }}px;
    height: {{ block.settings.icon_size_3 }}px;
  }

  .ai-trust-bar__icon-svg-3-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_3 }}px;
    height: {{ block.settings.icon_size_3 }}px;
  }

  .ai-trust-bar__icon-svg-3-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color_3 }};
    fill: none;
  }

  .ai-trust-bar__text-3-{{ ai_gen_id }} {
    color: {{ block.settings.text_color_3 }};
    font-size: {{ block.settings.font_size_3 }}px;
    font-weight: {{ block.settings.font_weight_3 }};
  }

  @media screen and (max-width: 749px) {
    .ai-trust-bar-{{ ai_gen_id }} {
      padding-top: {{ block.settings.mobile_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-trust-bar__items-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: {{ block.settings.spacing_between_items | times: 0.75 }}px;
    }

    .ai-trust-bar__item-{{ ai_gen_id }}:not(:last-child) {
      padding-right: 0;
      border-right: none;
      {% if block.settings.show_divider %}
        padding-bottom: {{ block.settings.spacing_between_items | times: 0.75 }}px;
        border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
        width: 100%;
      {% endif %}
    }

    .ai-trust-bar__text-{{ ai_gen_id }},
    .ai-trust-bar__text-2-{{ ai_gen_id }},
    .ai-trust-bar__text-3-{{ ai_gen_id }} {
      white-space: normal;
    }
  }
{% endstyle %}

