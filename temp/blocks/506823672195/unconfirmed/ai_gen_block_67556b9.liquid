{% doc %}
  @prompt
    Create a customizable Shopify section with a horizontal split layout (50/50).
    Requirements:
    The section should have two equal halves (left and right).
    Each half must have its own background color (editable in settings).
    Each half should contain editable text (headline).
    Text should be centered vertically and horizontally.
    Allow customization for:
    Left text content
    Right text content
    Left background color
    Right background color
    Text color for both sides
    Font size and font weight
    Make the section responsive (stack vertically on mobile).
    Add optional spacing (padding top/bottom).
    Use clean, modern styling similar to Shopify Dawn theme.
    Default example:
    Left side: "BUY 2 GET 1 FREE"
    Right side: "BUNDLE WITH A BESTSELLER"
    Ensure the section is easy to reuse and customizable from the Shopify theme editor., Create a Shopify section with a 50/50 split layout that looks clean on both desktop and mobile.
    
    Requirements:
    
    Layout:
    
    * Two equal columns (left and right) on desktop (50% width each).
    * On mobile, stack the sections vertically (one on top of the other).
    * Each block must always have equal height on desktop.
    
    Styling:
    
    * Each side has its own editable background color.
    * Text must be perfectly centered (both vertically and horizontally).
    * Use flexbox for alignment (not absolute positioning).
    * Add consistent padding (e.g. 20px–40px).
    
    Text:
    
    * Editable text for left and right side.
    * Allow control for:
    
      * Font size (desktop + mobile separately)
      * Font weight
      * Text color
    
    Mobile optimization (VERY IMPORTANT):
    
    * Ensure no extra spacing or uneven heights.
    * Make both stacked sections look like clean banners.
    * Reduce font size slightly on mobile.
    * Keep text centered and visually balanced.
    
    Optional:
    
    * Add a subtle divider line between sections (desktop only).
    * Add hover effect (slight brightness change).
    
    Default content:
    
    * Left: "BUY 2 GET 1 FREE"
    * Right: "BUNDLE WITH A BESTSELLER"
    
    Important:
    
    * The section must look like a clean promotional banner, not like two separate boxes.
    * Avoid large empty gaps or misalignment on mobile.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-split-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-promo-split__container-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    {% if block.settings.show_divider %}
      gap: 1px;
      background-color: {{ block.settings.divider_color }};
    {% endif %}
  }

  .ai-promo-split__panel-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.padding_desktop }}px;
    min-height: {{ block.settings.min_height_desktop }}px;
    transition: filter 0.3s ease;
  }

  {% if block.settings.enable_hover %}
    .ai-promo-split__panel-{{ ai_gen_id }}:hover {
      filter: brightness(1.1);
    }
  {% endif %}

  .ai-promo-split__panel--left-{{ ai_gen_id }} {
    background-color: {{ block.settings.left_bg_color }};
  }

  .ai-promo-split__panel--right-{{ ai_gen_id }} {
    background-color: {{ block.settings.right_bg_color }};
  }

  .ai-promo-split__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size_desktop }}px;
    font-weight: {{ block.settings.font_weight }};
    text-align: center;
    margin: 0;
    line-height: 1.3;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {{ block.settings.text_transform }};
    max-width: 100%;
    word-wrap: break-word;
  }

  @media screen and (max-width: 749px) {
    .ai-promo-split__container-{{ ai_gen_id }} {
      flex-direction: column;
      {% if block.settings.show_divider %}
        gap: 1px;
      {% else %}
        gap: 0;
      {% endif %}
    }

    .ai-promo-split__panel-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_mobile }}px;
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-promo-split__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<promo-split-{{ ai_gen_id }} class="ai-promo-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-split__container-{{ ai_gen_id }}">
    <div class="ai-promo-split__panel-{{ ai_gen_id }} ai-promo-split__panel--left-{{ ai_gen_id }}">
      {% if block.settings.left_text != blank %}
        <h2 class="ai-promo-split__text-{{ ai_gen_id }}">{{ block.settings.left_text }}</h2>
      {% endif %}
    </div>
    <div class="ai-promo-split__panel-{{ ai_gen_id }} ai-promo-split__panel--right-{{ ai_gen_id }}">
      {% if block.settings.right_text != blank %}
        <h2 class="ai-promo-split__text-{{ ai_gen_id }}">{{ block.settings.right_text }}</h2>
      {% endif %}
    </div>
  </div>
</promo-split-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoSplit{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('promo-split-{{ ai_gen_id }}', PromoSplit{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Promo split banner",
  "settings": [
    {
      "type": "header",
      "content": "Left panel"
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Text",
      "default": "BUY 2 GET 1 FREE"
    },
    {
      "type": "color",
      "id": "left_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Right panel"
    },
    {
      "type": "text",
      "id": "right_text",
      "label": "Text",
      "default": "BUNDLE WITH A BESTSELLER"
    },
    {
      "type": "color",
      "id": "right_bg_color",
      "label": "Background color",
      "default": "#1c1c1c"
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Font size (desktop)",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size (mobile)",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Minimum height (desktop)",
      "min": 80,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 160
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Minimum height (mobile)",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "label": "Padding (desktop)",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "label": "Padding (mobile)",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Effects"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider line",
      "default": true
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_hover",
      "label": "Enable hover effect",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Promo split banner"
    }
  ]
}
{% endschema %}