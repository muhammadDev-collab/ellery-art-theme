{% doc %}
  @prompt
    price
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-price-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-price-container-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.alignment }};
    gap: {{ block.settings.price_gap }}px;
    flex-wrap: wrap;
    justify-content: {{ block.settings.justify }};
  }

  .ai-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.price_color }};
  }

  .ai-price-{{ ai_gen_id }}--on-sale {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-price-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.badge_border_radius }}px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-price-unit-{{ ai_gen_id }} {
    font-size: {{ block.settings.unit_price_size }}px;
    color: {{ block.settings.unit_price_color }};
    margin-top: {{ block.settings.unit_price_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-price-container-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width_percent }}%;
    }

    .ai-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.price_size }}px * 0.9);
    }

    .ai-compare-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.compare_price_size }}px * 0.9);
    }
  }

  @media screen and (min-width: 750px) {
    .ai-price-container-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }
{% endstyle %}

<price-display-{{ ai_gen_id }} class="ai-price-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product %}
    <div class="ai-price-container-{{ ai_gen_id }}">
      {% if product.compare_at_price > product.price %}
        <span class="ai-compare-price-{{ ai_gen_id }}">
          {{ product.compare_at_price | money_without_trailing_zeros }}
        </span>
        <span class="ai-price-{{ ai_gen_id }} ai-price-{{ ai_gen_id }}--on-sale">
          {{ product.price | money_without_trailing_zeros }}
        </span>
        {% if block.settings.show_sale_badge %}
          <span class="ai-price-badge-{{ ai_gen_id }}">
            {% if block.settings.sale_badge_text != blank %}
              {{ block.settings.sale_badge_text }}
            {% else %}
              Sale
            {% endif %}
          </span>
        {% endif %}
      {% else %}
        <span class="ai-price-{{ ai_gen_id }}">
          {{ product.price | money_without_trailing_zeros }}
        </span>
      {% endif %}
    </div>

    {% if block.settings.show_unit_price and product.selected_or_first_available_variant.unit_price_measurement %}
      <div class="ai-price-unit-{{ ai_gen_id }}">
        {{ product.selected_or_first_available_variant.unit_price | money_without_trailing_zeros }}
        /
        {% if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 %}
          {{ product.selected_or_first_available_variant.unit_price_measurement.reference_value }}
        {% endif %}
        {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
      </div>
    {% endif %}
  {% else %}
    <div class="ai-price-container-{{ ai_gen_id }}">
      <span class="ai-compare-price-{{ ai_gen_id }}">{{ 9900 | money_without_trailing_zeros }}</span>
      <span class="ai-price-{{ ai_gen_id }} ai-price-{{ ai_gen_id }}--on-sale">{{ 7900 | money_without_trailing_zeros }}</span>
      {% if block.settings.show_sale_badge %}
        <span class="ai-price-badge-{{ ai_gen_id }}">
          {% if block.settings.sale_badge_text != blank %}
            {{ block.settings.sale_badge_text }}
          {% else %}
            Sale
          {% endif %}
        </span>
      {% endif %}
    </div>
  {% endif %}
</price-display-{{ ai_gen_id }}>

<script>
  (function() {
    class PriceDisplay{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupVariantListener();
      }

      setupVariantListener() {
        if (typeof window.Shopify === 'undefined' || !window.Shopify.ProductForm) return;

        const productForm = document.querySelector('product-form');
        if (!productForm) return;

        productForm.addEventListener('variant:change', (event) => {
          this.updatePrice(event.detail.variant);
        });
      }

      updatePrice(variant) {
        if (!variant) return;

        const priceContainer = this.querySelector('.ai-price-container-{{ ai_gen_id }}');
        if (!priceContainer) return;

        const hasComparePrice = variant.compare_at_price && variant.compare_at_price > variant.price;
        
        let priceHTML = '';
        
        if (hasComparePrice) {
          priceHTML = `
            <span class="ai-compare-price-{{ ai_gen_id }}">${this.formatMoney(variant.compare_at_price)}</span>
            <span class="ai-price-{{ ai_gen_id }} ai-price-{{ ai_gen_id }}--on-sale">${this.formatMoney(variant.price)}</span>
          `;
          
          const showBadge = {{ block.settings.show_sale_badge | json }};
          if (showBadge) {
            const badgeText = {{ block.settings.sale_badge_text | json }} || 'Sale';
            priceHTML += `<span class="ai-price-badge-{{ ai_gen_id }}">${badgeText}</span>`;
          }
        } else {
          priceHTML = `<span class="ai-price-{{ ai_gen_id }}">${this.formatMoney(variant.price)}</span>`;
        }
        
        priceContainer.innerHTML = priceHTML;

        const unitPriceElement = this.querySelector('.ai-price-unit-{{ ai_gen_id }}');
        if (unitPriceElement && variant.unit_price) {
          let referenceValue = variant.unit_price_measurement.reference_value !== 1 
            ? variant.unit_price_measurement.reference_value 
            : '';
          unitPriceElement.innerHTML = `${this.formatMoney(variant.unit_price)} / ${referenceValue}${variant.unit_price_measurement.reference_unit}`;
          unitPriceElement.style.display = 'block';
        } else if (unitPriceElement) {
          unitPriceElement.style.display = 'none';
        }
      }

      formatMoney(cents) {
        if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
          return Shopify.formatMoney(cents);
        }
        return {{ shop.currency_symbol | json }} + (cents / 100).toFixed(2);
      }
    }

    customElements.define('price-display-{{ ai_gen_id }}', PriceDisplay{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
