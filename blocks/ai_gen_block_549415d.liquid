    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Sale color",
      "default": "#c82e2d"
    },
    {
      "type": "header",
      "content": "Compare at price"
    },
    {
      "type": "range",
      "id": "compare_price_size",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 18
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Color",
      "default": "#303030"
    },
    {
      "type": "header",
      "content": "Sale badge"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
